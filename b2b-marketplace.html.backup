// ── MAP INIT ──────────────────────────────────────────────────────────────────
const map = L.map('map', { center: [54, 10], zoom: 4, zoomControl: true });
L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
  attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
  maxZoom: 19
}).addTo(map);

radiusCircle = L.circle(AROUCA, {
  radius: 25000, color:'#f97316', fillColor:'#f97316',
  fillOpacity: 0.12, weight: 2.5, dashArray:'5,4'
}).addTo(map);

// ── MARKERS ───────────────────────────────────────────────────────────────────
function createMarkerIcon(c) {
  const bg   = c.pinType === 'gold' ? '#f59e0b' : (c.isNew ? '#10b981' : '#f97316');
  const glow = c.pinType === 'gold' ? 'rgba(245,158,11,.4)' : (c.isNew ? 'rgba(16,185,129,.35)' : 'rgba(249,115,22,.4)');
  return L.divIcon({
    className: '',
    html: `<div style="width:38px;height:44px;position:relative;cursor:pointer">
      <div style="width:38px;height:38px;background:${bg};border-radius:50% 50% 50% 0;transform:rotate(-45deg);display:flex;align-items:center;justify-content:center;box-shadow:0 3px 12px ${glow};border:2.5px solid #fff">
        <span style="transform:rotate(45deg);font-size:16px;display:block;line-height:1">${c.emoji}</span>
      </div>
    </div>`,
    iconSize:[38,44], iconAnchor:[19,44], popupAnchor:[0,-46]
  });
}

function buildPopupHtml(c) {
  const tr = translations[currentLang];
  const starsHtml = c.rating > 0
    ? `<div style="color:#f59e0b;font-size:13px;margin-bottom:3px">${'★'.repeat(Math.floor(c.rating))}${'☆'.repeat(5-Math.floor(c.rating))} <strong style="color:#1e293b">${c.rating}</strong> <span style="color:#64748b;font-size:11px">(${c.reviews} ${tr.reviews})</span></div>`
    : `<div style="font-size:11px;color:#64748b;margin-bottom:3px">⭐ ${tr.popupNoRatings}</div>`;
  return `<div style="min-width:180px">
    <div style="font-size:14px;font-weight:700;margin-bottom:3px">${c.emoji} ${c.name}</div>
    <div style="font-size:11.5px;color:#64748b;margin-bottom:5px">${c.cae}</div>
    ${starsHtml}
    <div style="font-size:11px;color:#64748b">📍 ${c.address}</div>
    ${c.isNew ? `<div style="font-size:10px;color:#166534;background:#dcfce7;border-radius:4px;padding:2px 6px;margin-top:5px;display:inline-block">${tr.popupNewBadge}</div>` : ''}
  </div>`;
}

function addCompanyMarker(c) {
  const m = L.marker([c.lat, c.lng], { icon: createMarkerIcon(c) }).addTo(map);
  m.bindPopup(buildPopupHtml(c));
  m.on('click', () => openDetail(c.id));
  markerMap[c.id] = m;
}

// Refresh all popup content when language changes (called in applyI18n → applyFilters)
function refreshPopups() {
  companies.forEach(c => {
    if (markerMap[c.id]) markerMap[c.id].setPopupContent(buildPopupHtml(c));
  });
}

function updateRadius(val) {
  val = parseInt(val, 10);
  document.getElementById('rv').textContent = val + ' km';

  // Update circle on map - multiply by 1000 to convert km to meters
  try {
    if (radiusCircle && typeof radiusCircle.setRadius === 'function') {
      radiusCircle.setRadius(val * 1000);
    }
  } catch (e) {
    console.error('Error updating radius:', e);
  }
}

// Geocode location and center map
function geocodeLocation(location) {
  if (!location || location.trim() === '') return;

  const query = encodeURIComponent(location);
  // Search worldwide without country restrictions
  fetch(`https://nominatim.openstreetmap.org/search?q=${query}&format=json&limit=1`)
    .then(r => r.json())
    .then(data => {
      if (data && data.length > 0) {
        const place = data[0];
        const lat = parseFloat(place.lat);
        const lng = parseFloat(place.lon);
        // Zoom to the location with appropriate zoom level
        const zoom = place.type === 'amenity' || place.type === 'building' ? 16 :
                     place.type === 'village' ? 13 :
                     place.type === 'town' ? 12 :
                     place.type === 'city' ? 11 :
                     place.type === 'county' ? 10 : 9;
        map.setView([lat, lng], zoom, { animate: true });
        // Update radius circle center
        if (radiusCircle) radiusCircle.setLatLng([lat, lng]);
        // Show location name in toast
        showToast(`📍 ${place.name || location}`);
      } else {
        showToast('Local não encontrado. Tente outro nome.');
      }
    })
    .catch(e => {
      console.error('Geocoding error:', e);
      showToast('Erro ao procurar localização.');
    });
}

// ── DYNAMIC SELECT RENDERING ──────────────────────────────────────────────────
function renderRegisterSectorSelect() {
  const tr  = translations[currentLang];
  const sel = document.getElementById('regSector');
  if (!sel) return;
  const cur = sel.value;
  sel.innerHTML = `<option value="">${tr.regSectorPh}</option>` +
    SECTOR_KEYS.map(k => `<option value="${k}">${tr.sectorOptions[k]}</option>`).join('');
  if (cur) sel.value = cur;
}

function renderRegisterZoneSelect() {
  const tr  = translations[currentLang];
  const sel = document.getElementById('regZone');
  if (!sel) return;
  const cur = sel.value;
  sel.innerHTML = ZONE_KEYS.map(k => `<option value="${k}">${tr.zones[k]}</option>`).join('');
  if (cur) sel.value = cur; else sel.value = 'lisbon_center';
}

function renderEmailTypeSelect() {
  const tr  = translations[currentLang];
  const sel = document.getElementById('emailTypeSelect');
  if (!sel) return;
  sel.innerHTML = tr.emailTypes.map(o => `<option>${o}</option>`).join('');
}

// ── FILTER SIDEBAR ────────────────────────────────────────────────────────────
function getSectorCounts() {
  const counts = {};
  companies.forEach(c => { counts[c.sector] = (counts[c.sector] || 0) + 1; });
  return counts;
}

function renderSectorFilters() {
  const container = document.getElementById('sectorFilters');
  const tr        = translations[currentLang];
  const counts    = getSectorCounts();
  container.innerHTML = '';

  const filterContainer = document.createElement('div');
  filterContainer.className = 'sector-filter-container';

  // Level 1: Main Category Groups
  Object.entries(SECTOR_HIERARCHY).forEach(([groupKey, group]) => {
    // Main group button
    const groupEl = document.createElement('div');
    groupEl.className = 'sector-category';
    groupEl.innerHTML = `
      <i data-lucide="${group.icon}" class="sector-cat-icon"></i>
      <span class="sector-cat-label">${group.label}</span>
      <span class="sector-cat-arrow">▼</span>
    `;

    // Categories container (Level 2)
    const categoriesContainer = document.createElement('div');
    categoriesContainer.className = 'sector-subcats';

    // Level 2: Categories
    Object.entries(group.categories).forEach(([categoryKey, category]) => {
      const categoryDiv = document.createElement('div');
      categoryDiv.style.marginLeft = '20px';
      categoryDiv.className = 'sector-category' ;
      categoryDiv.style.fontSize = '12px';
      categoryDiv.style.marginBottom = '6px';
      categoryDiv.innerHTML = `
        <i class="sector-cat-icon" style="font-size:11px">📁</i>
        <span class="sector-cat-label">${category.label}</span>
        <span class="sector-cat-arrow">▼</span>
      `;

      // Subcategories container (Level 3)
      const subcatsContainer = document.createElement('div');
      subcatsContainer.className = 'sector-subcats';
      subcatsContainer.style.marginLeft = '0';

      // Level 3: Specific Subcategories
      Object.entries(category.subcategories).forEach(([subcatKey, subcatLabel]) => {
        const subcatDiv = document.createElement('div');
        subcatDiv.className = 'sector-subcat';
        const count = counts[subcatKey] || 0;
        subcatDiv.innerHTML = `
          <input type="checkbox" id="sector_${subcatKey}" value="${subcatKey}"/>
          <label for="sector_${subcatKey}">
            ${subcatLabel} <span class="fcount">${count}</span>
          </label>`;

        const checkbox = subcatDiv.querySelector('input');
        checkbox.addEventListener('change', () => toggleSector(subcatKey));
        if (activeSectors.has(subcatKey)) checkbox.checked = true;
        subcatsContainer.appendChild(subcatDiv);
      });

      // Toggle Level 2 category
      categoryDiv.addEventListener('click', (e) => {
        e.stopPropagation();
        categoryDiv.classList.toggle('open');
        subcatsContainer.classList.toggle('show');
      });

      // Check if any subcategory is selected
      const anySelected = Object.keys(category.subcategories).some(k => activeSectors.has(k));
      if (anySelected) {
        categoryDiv.classList.add('open');
        subcatsContainer.classList.add('show');
      }

      categoriesContainer.appendChild(categoryDiv);
      categoriesContainer.appendChild(subcatsContainer);
    });

    // Toggle Level 1 group
    groupEl.addEventListener('click', () => {
      groupEl.classList.toggle('open');
      categoriesContainer.classList.toggle('show');
    });

    // Check if any category in this group has selections
    let groupHasSelections = false;
    Object.values(group.categories).forEach(cat => {
      const hasSelections = Object.keys(cat.subcategories).some(k => activeSectors.has(k));
      if (hasSelections) groupHasSelections = true;
    });

    if (groupHasSelections) {
      groupEl.classList.add('open');
      categoriesContainer.classList.add('show');
    }

    filterContainer.appendChild(groupEl);
    filterContainer.appendChild(categoriesContainer);
  });

  container.appendChild(filterContainer);
  if (typeof lucide !== 'undefined') lucide.createIcons();
}

function renderTagCloud() {
  const container = document.getElementById('tagsCloud');
  const allTags   = [...new Set(companies.flatMap(c => c.tags))].sort();
  container.innerHTML = '';
  allTags.forEach(tag => {
    const span = document.createElement('span');
    span.className   = 'tag-pill' + (activeTag === tag ? ' active' : '');
    span.textContent = tag;
    span.addEventListener('click', () => toggleTagFilter(tag));
    container.appendChild(span);
  });
}

function toggleSector(sector) {
  if (activeSectors.has(sector)) activeSectors.delete(sector);
  else activeSectors.add(sector);
  applyFilters();
}

function toggleTagFilter(tag) {
  activeTag = (activeTag === tag) ? null : tag;
  renderTagCloud();
  applyFilters();
}

// ── FILTER LOGIC ──────────────────────────────────────────────────────────────
// Calculate distance between two coordinates (Haversine formula) - returns km
function calculateDistance(lat1, lon1, lat2, lon2) {
  const R = 6371; // Earth radius in km
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;
  const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLon/2) * Math.sin(dLon/2);
  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  return R * c;
}

function getFiltered() {
  let res = [...companies];

  // Filter by radius
  const radiusSlider = document.getElementById('radiusSlider');
  const searchRadius = radiusSlider ? parseInt(radiusSlider.value, 10) : 25;
  const mapCenter = map.getCenter();
  res = res.filter(c => {
    const distance = calculateDistance(mapCenter.lat, mapCenter.lng, c.lat, c.lng);
    return distance <= searchRadius;
  });

  if (activeSectors.size > 0) res = res.filter(c => activeSectors.has(c.sector));
  const ratingEl  = document.querySelector('input[name="minRating"]:checked');
  const minRating = ratingEl ? parseFloat(ratingEl.value) : 0;
  if (minRating > 0) res = res.filter(c => c.rating >= minRating);
  if (document.getElementById('filterTopRated')?.checked) res = res.filter(c => c.topRated);
  if (document.getElementById('filterVerified')?.checked) res = res.filter(c => c.verified === true);
  if (document.getElementById('filterNew')?.checked)      res = res.filter(c => c.isNew === true);
  if (activeTag) res = res.filter(c => c.tags.includes(activeTag));
  const kw = document.getElementById('kwInput').value.trim().toLowerCase();
  if (kw) res = res.filter(c =>
    c.name.toLowerCase().includes(kw) ||
    c.cae.toLowerCase().includes(kw)  ||
    c.tags.some(tag => tag.toLowerCase().includes(kw))
  );
  const sort = document.querySelector('input[name="sort"]:checked')?.value || 'rating';
  if (sort === 'rating')  res.sort((a,b) => b.rating  - a.rating);
  else if (sort === 'reviews') res.sort((a,b) => b.reviews - a.reviews);
  else res.sort((a,b) => a.name.localeCompare(b.name));
  return res;
}

function applyFilters() {
  const filtered = getFiltered();
  updateMarkers(filtered);
  document.getElementById('countNum').textContent = filtered.length;
  refreshPopups();

  // Center map on first filtered result if available
  if (filtered.length > 0) {
    const first = filtered[0];
    map.setView([first.lat, first.lng], 13, { animate: true });
  }
}

function updateMarkers(filtered) {
  const ids = new Set(filtered.map(c => c.id));
  companies.forEach(c => {
    if (!markerMap[c.id]) return;
    if (ids.has(c.id)) { if (!map.hasLayer(markerMap[c.id])) markerMap[c.id].addTo(map); }
    else               { if (map.hasLayer(markerMap[c.id]))  map.removeLayer(markerMap[c.id]); }
  });
}

function clearAllFilters() {
  activeSectors.clear();
  activeTag = null;
  document.querySelectorAll('#sectorFilters input[type=checkbox]').forEach(cb => cb.checked = false);
  document.getElementById('filterTopRated').checked = false;
  document.getElementById('filterVerified').checked = false;
  document.getElementById('filterNew').checked      = false;
  document.getElementById('ratingAny').checked      = true;
  document.getElementById('kwInput').value          = '';
  document.getElementById('sortRating').checked     = true;
  document.getElementById('radiusSlider').value     = 25;
  updateRadius(25);
  renderTagCloud();
  applyFilters();
  showToast(t('toastFiltersCleared'));
}

// ── REGISTER COMPANY ──────────────────────────────────────────────────────────
function openRegister() {
  document.getElementById('registerOverlay').classList.add('open');
  // Initialize country dropdown
  renderRegisterCountrySelect();
  renderRegisterCitySelect('pt');
}

function closeRegister() { document.getElementById('registerOverlay').classList.remove('open'); }
function closeRegisterIfBg(e) { if (e.target === document.getElementById('registerOverlay')) closeRegister(); }

function renderRegisterCountrySelect() {
  const sel = document.getElementById('regCountry');
  if (!sel) return;
  // Country select already has options from HTML
  sel.addEventListener('change', function() {
    renderRegisterCitySelect(this.value);
  });
}

function renderRegisterCitySelect(country) {
  const sel = document.getElementById('regCity');
  if (!sel) return;

  const cities = CITIES_BY_COUNTRY[country] || ['Selecione um país primeiro'];
  sel.innerHTML = '<option value="">Selecione uma cidade</option>' +
    cities.map(c => `<option value="${c}">${c}</option>`).join('');
}

function submitRegister() {
  const name    = document.getElementById('regName').value.trim();
  const sector  = document.getElementById('regSector').value;
  const cae     = document.getElementById('regCae').value.trim();
  const address = document.getElementById('regAddress').value.trim();
  const country = document.getElementById('regCountry').value;
  const city    = document.getElementById('regCity').value;
  const postalCode = document.getElementById('regPostalCode').value.trim();
  const email   = document.getElementById('regEmail').value.trim();
  const tagsRaw = document.getElementById('regTags').value.trim();

  if (!name)    { showToast(t('valName'));    return; }
  if (!sector)  { showToast(t('valSector'));  return; }
  if (!address) { showToast(t('valAddress')); return; }
  if (!email)   { showToast(t('valEmail'));   return; }
  if (!tagsRaw) { showToast(t('valTags'));    return; }
  if (!country) { showToast('Selecione um país'); return; }
  if (!city)    { showToast('Selecione uma cidade'); return; }
  if (!postalCode) { showToast('Introduza o código postal'); return; }

  const tags   = tagsRaw.split(',').map(s => s.trim()).filter(Boolean);
  const idx    = nextCompanyId % defaultEmojis.length;
  const tr     = translations[currentLang];
  const zone   = document.getElementById('regZone').value;
  const defaultCoords = zoneCoords[zone] || LISBON;

  // Geocode using postal code as the primary identifier for precise location
  const fullAddress = `${address}, ${postalCode}, ${city}, ${country}`;

  // Try geocoding with postal code first (most precise)
  const postalCodeQuery = encodeURIComponent(`${postalCode}, ${city}, ${country}`);

  fetch(`https://nominatim.openstreetmap.org/search?q=${postalCodeQuery}&format=json&limit=1`)
    .then(r => r.json())
    .then(primaryData => {
      let lat, lng;

      if (primaryData && primaryData.length > 0) {
        // Postal code found - use it
        lat = parseFloat(primaryData[0].lat);
        lng = parseFloat(primaryData[0].lon);
        processRegistration(lat, lng);
      } else {
        // Fallback: try with full address if postal code alone doesn't work
        const fullAddressQuery = encodeURIComponent(fullAddress);
        return fetch(`https://nominatim.openstreetmap.org/search?q=${fullAddressQuery}&format=json&limit=1`)
          .then(r => r.json())
          .then(fallbackData => {
            if (fallbackData && fallbackData.length > 0) {
              lat = parseFloat(fallbackData[0].lat);
              lng = parseFloat(fallbackData[0].lon);
            } else {
              // Last resort: use city location
              lat = defaultCoords[0] + (Math.random() - 0.5) * 0.02;
              lng = defaultCoords[1] + (Math.random() - 0.5) * 0.02;
            }
            processRegistration(lat, lng);
          });
      }
    })
    .then(() => {})
    .catch(e => {
      console.error('Geocoding error:', e);
      showToast('Erro ao processar localização. Tente novamente.');
    });

  function processRegistration(lat, lng) {
    const newCompany = {
      id: nextCompanyId++, name,
      cae: cae || `${tr.sectorOptions[sector] || sector}`,
      sector, rating: 0, reviews: 0,
      topRated: false, verified: false, isNew: true,
      tags, color: defaultColors[idx], emoji: defaultEmojis[idx], pinType: 'std',
      lat, lng,
      address: fullAddress,
      axes:[
        {l:'quality',v:0},{l:'deadlines',v:0},{l:'communication',v:0},{l:'price',v:0}
      ]
    };

    companies.push(newCompany);
    addCompanyMarker(newCompany);
    renderSectorFilters();
    renderTagCloud();

    ['regName','regCae','regAddress','regEmail','regPhone','regWebsite','regTags','regDesc','regPostalCode']
      .forEach(id => { document.getElementById(id).value = ''; });
    document.getElementById('regSector').value = '';
    document.getElementById('regCountry').value = '';
    document.getElementById('regCity').value = '';
    document.getElementById('regZone').value   = 'lisbon_center';

    closeRegister();
    applyFilters();
    showToast(t('toastRegistered')(name));
    setTimeout(() => {
      map.flyTo([newCompany.lat, newCompany.lng], 14, { animate: true, duration: 1.5 });
      setTimeout(() => markerMap[newCompany.id]?.openPopup(), 1600);
    }, 300);
  }
}

// ── DETAIL PANEL ──────────────────────────────────────────────────────────────
function openDetail(id) {
  const c  = companies.find(x => x.id === id);
  if (!c) return;
  const tr = translations[currentLang];
  selectedId = id;

  document.getElementById('dpLogo').textContent        = c.emoji;
  document.getElementById('dpLogo').style.background   = c.color;
  document.getElementById('dpName').textContent        = c.name;
  document.getElementById('dpSub').textContent         =
    c.rating > 0 ? `${c.cae} · ⭐ ${c.rating} (${c.reviews} ${tr.reviews})`
                 : `${c.cae} · ⭐ ${tr.noRatings}`;
  document.getElementById('dpAddress').textContent = c.address;

  document.getElementById('dpRatings').innerHTML = c.axes.map(a => {
    const label = tr.axisLabels[a.l] || a.l;
    return `<div class="rating-axis">
      <div class="axis-label">${label}</div>
      <div class="axis-bar"><div class="axis-fill" style="width:${a.v}%"></div></div>
      <div class="axis-val">${a.v > 0 ? (a.v/20).toFixed(1)+' / 5.0' : 'N/A'}</div>
    </div>`;
  }).join('');

  document.getElementById('dpTags').innerHTML = c.tags.map(tag =>
    `<span class="tag">${tag}</span>`).join('');
  document.getElementById('chatName').textContent = c.name;
  document.getElementById('dpReviewsSection').style.display = c.isNew ? 'none' : 'block';
  document.getElementById('detailPanel').classList.add('open');

  // Get current map center
  const mapCenter = map.getCenter();
  const fromLat = mapCenter.lat;
  const fromLng = mapCenter.lng;
  const toLat = c.lat;
  const toLng = c.lng;

  // Calculate distance to determine if route is needed
  const distance = calculateDistance(fromLat, fromLng, toLat, toLng);

  // If more than 500m away, draw route
  if (distance > 0.5) {
    drawRoute(fromLat, fromLng, toLat, toLng, c.name);
  } else {
    // Clear previous route if destination is very close
    if (routePolyline) {
      map.removeLayer(routePolyline);
      routePolyline = null;
    }
  }

  map.flyTo([c.lat, c.lng], 15, { animate: true, duration: 1.2 });
  setTimeout(() => markerMap[c.id]?.openPopup(), 1300);
}

// Draw route between two points
function drawRoute(fromLat, fromLng, toLat, toLng, companyName) {
  // Clear previous route
  if (routePolyline) {
    map.removeLayer(routePolyline);
    routePolyline = null;
  }

  const url = `https://router.project-osrm.org/route/v1/driving/${fromLng},${fromLat};${toLng},${toLat}?overview=full&geometries=geojson`;

  fetch(url)
    .then(r => r.json())
    .then(data => {
      if (data.routes && data.routes.length > 0) {
        const route = data.routes[0];
        const coordinates = route.geometry.coordinates.map(coord => [coord[1], coord[0]]);

        // Draw polyline
        routePolyline = L.polyline(coordinates, {
          color: '#f97316',
          weight: 4,
          opacity: 0.8,
          dashArray: '5,5',
          className: 'route-line'
        }).addTo(map);

        // Calculate time
        const durationSeconds = route.duration;
        const durationMinutes = Math.round(durationSeconds / 60);
        const durationHours = Math.floor(durationMinutes / 60);
        const remainingMinutes = durationMinutes % 60;

        let timeText = '';
        if (durationHours > 0) {
          timeText = `${durationHours}h ${remainingMinutes}m`;
        } else {
          timeText = `${durationMinutes}m`;
        }

        // Distance in km
        const distanceKm = (route.distance / 1000).toFixed(1);

        // Show toast with route info
        showToast(`🛣️ ${companyName}: ${distanceKm}km · ${timeText}`);
      }
    })
    .catch(e => {
      console.error('Routing error:', e);
    });
}

function closeDetail() {
  document.getElementById('detailPanel').classList.remove('open');
  selectedId = null;
  map.flyTo(LISBON, 12, { animate: true, duration: 1 });
}

// ── CHAT ──────────────────────────────────────────────────────────────────────
function toggleChat() { chatOpen ? closeChat() : openChat(); }
function openChat() {
  document.getElementById('chatBox').classList.add('open');
  chatOpen = true;
  document.getElementById('chatNotif').style.display = 'none';
}
function openChatFor(name) { document.getElementById('chatName').textContent = name; openChat(); }
function closeChat() { document.getElementById('chatBox').classList.remove('open'); chatOpen = false; }
function sendMsg(e) { if (e.key === 'Enter') sendMsgBtn(); }
function sendMsgBtn() {
  const inp  = document.getElementById('chatInput');
  const txt  = inp.value.trim();
  if (!txt) return;
  const msgs = document.getElementById('chatMsgs');
  const now  = new Date();
  const time = now.getHours() + ':' + String(now.getMinutes()).padStart(2,'0');
  const d    = document.createElement('div');
  d.className = 'msg msg-out';
  d.innerHTML = `<div class="msg-bubble">${txt}</div><div class="msg-time">${time} ✓</div>`;
  msgs.appendChild(d);
  inp.value = '';
  msgs.scrollTop = msgs.scrollHeight;
  setTimeout(() => {
    const r = document.createElement('div');
    r.className = 'msg msg-in';
    r.innerHTML = `<div class="msg-bubble">${t('toastAutoReply')}</div><div class="msg-time">${time}</div>`;
    msgs.appendChild(r);
    msgs.scrollTop = msgs.scrollHeight;
  }, 1200);
}

// ── EMAIL ──────────────────────────────────────────────────────────────────────
function openEmail()  { document.getElementById('emailOverlay').classList.add('open'); }
function closeEmail() { document.getElementById('emailOverlay').classList.remove('open'); }
function closeEmailIfBg(e) { if (e.target === document.getElementById('emailOverlay')) closeEmail(); }
function submitEmail() { closeEmail(); showToast(t('toastEmailSent')); }

// ── TOAST ──────────────────────────────────────────────────────────────────────
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2800);
}

// ── GEOLOCATION ────────────────────────────────────────────────────────────────
let userLocationMarker = null;

function detectUserLocation(auto = false) {
  if (!navigator.geolocation) {
    if (!auto) showToast('Geolocalização não suportada neste browser.');
    return;
  }

  const btn = document.getElementById('btnLocate');

  if (!auto && btn) {
    btn.classList.add('locating');
    btn.title = 'A detetar localização...';
  }

  navigator.geolocation.getCurrentPosition(
    pos => {
      const { latitude: lat, longitude: lng, accuracy } = pos.coords;

      // Fly map to user position
      map.flyTo([lat, lng], 13, { duration: 1.8 });

      // Remove previous marker
      if (userLocationMarker) { userLocationMarker.remove(); userLocationMarker = null; }

      // Pulsing orange "you are here" marker
      const youIcon = L.divIcon({
        className: '',
        html: `<div style="position:relative;width:24px;height:24px">
          <div style="position:absolute;inset:0;background:rgba(249,115,22,.25);border-radius:50%;animation:pulse 2s infinite"></div>
          <div style="position:absolute;inset:5px;background:#f97316;border-radius:50%;border:2.5px solid #fff;box-shadow:0 2px 10px rgba(249,115,22,.7)"></div>
        </div>`,
        iconSize: [24, 24],
        iconAnchor: [12, 12],
      });

      userLocationMarker = L.marker([lat, lng], { icon: youIcon, zIndexOffset: 1000 })
        .addTo(map)
        .bindPopup(`<strong>📍 A sua localização</strong><br><small style="color:#6b7280">Precisão: ±${Math.round(accuracy)} m</small>`);

      if (!auto) userLocationMarker.openPopup();

      // Reverse geocode with Nominatim
      fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&accept-language=pt`)
        .then(r => r.json())
        .then(data => {
          const a = data.address || {};
          const city = a.city || a.town || a.village || a.municipality || '';
          const country = a.country || '';
          const label = [city, country].filter(Boolean).join(', ');
          if (label) {
            document.getElementById('locInput').value = label;
            // update map info box city
            const cityEl = document.querySelector('[data-i18n="mapCity"]');
            if (cityEl) cityEl.textContent = label;
          }
        })
        .catch(() => {});

      if (btn) { btn.classList.remove('locating'); btn.title = 'Usar localização atual'; }
      if (!auto) showToast('Localização detetada!');
    },
    err => {
      if (btn) { btn.classList.remove('locating'); btn.title = 'Usar localização atual'; }

      // Fallback to Arouca
      currentMapCenter = AROUCA;
      map.setView(AROUCA, 12, { animate: true });
      radiusCircle.setLatLng(AROUCA);
      document.getElementById('locInput').value = 'Arouca, Portugal';
      const cityEl = document.querySelector('[data-i18n="mapCity"]');
      if (cityEl) cityEl.textContent = 'Arouca, Portugal';

      if (!auto) {
        const msgs = { 1: 'Permissão de localização negada.', 2: 'Posição não disponível.', 3: 'Tempo de espera excedido.' };
        showToast(msgs[err.code] || 'Erro ao obter localização.');
      }
    },
    { timeout: 10000, enableHighAccuracy: true }
  );
}

// ── INIT ───────────────────────────────────────────────────────────────────────
renderRegisterSectorSelect();
renderRegisterZoneSelect();
renderEmailTypeSelect();
renderSectorFilters();
renderTagCloud();
applyI18n();   // applies all translations + calls applyFilters

// Convert all <i data-lucide="..."> to SVG icons
if (typeof lucide !== 'undefined') lucide.createIcons();

// Setup radius slider event listeners
let radiusTimeout;
setTimeout(() => {
  const radiusSlider = document.getElementById('radiusSlider');
  if (radiusSlider) {
    radiusSlider.addEventListener('input', function(e) {
      updateRadius(e.target.value);
      // Debounce applyFilters while dragging
      clearTimeout(radiusTimeout);
      radiusTimeout = setTimeout(() => applyFilters(), 300);
    });
    radiusSlider.addEventListener('change', function() {
      clearTimeout(radiusTimeout);
      applyFilters();
    });
  }

  // Setup location input listener
  const locInput = document.getElementById('locInput');
  if (locInput) {
    locInput.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        geocodeLocation(this.value);
        applyFilters();
      }
    });
  }

  // Setup search button to also center on first result
  const btnSearch = document.getElementById('btnSearch');
  if (btnSearch) {
    btnSearch.addEventListener('click', function() {
      const locValue = document.getElementById('locInput').value;
      if (locValue && locValue.trim() !== '') {
        geocodeLocation(locValue);
      }
    });
  }
}, 100);

// Auto-detect user location silently (centres map, no toast)
// Try immediately, with short delay to ensure map is ready
setTimeout(() => detectUserLocation(true), 50);

// Hide nav on scroll
let lastScrollTop = 0;
const nav = document.querySelector('nav');
const detailPanel = document.querySelector('.detail-panel');
const searchBar = document.querySelector('.search-bar');
const main = document.querySelector('.main');

function hideNavOnScroll(currentScrollTop) {
  if (!nav) return;

  if (currentScrollTop > lastScrollTop && currentScrollTop > 30) {
    // Scrolling DOWN - hide nav, map and filters expand
    nav.classList.add('scrolled');
    if (detailPanel) {
      detailPanel.style.top = '60px';
      detailPanel.style.height = 'calc(100vh - 60px)';
    }
    if (searchBar) {
      searchBar.style.opacity = '0.5';
      searchBar.style.pointerEvents = 'none';
    }
    if (main) {
      main.style.flex = '1';
    }
  } else if (currentScrollTop < lastScrollTop - 10) {
    // Scrolling UP - show nav, map and filters return to normal
    nav.classList.remove('scrolled');
    if (detailPanel) {
      detailPanel.style.top = '230px';
      detailPanel.style.height = 'calc(100vh - 230px)';
    }
    if (searchBar) {
      searchBar.style.opacity = '';
      searchBar.style.pointerEvents = '';
    }
    if (main) {
      main.style.flex = '1';
    }
  }

  lastScrollTop = currentScrollTop;
}

// Listen to scroll events on all possible elements
window.addEventListener('wheel', (e) => {
  const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
  hideNavOnScroll(scrollTop);
}, { passive: true });

// Also try to detect scroll within the page
setTimeout(() => {
  const mainElements = [
    document.getElementById('tab-search'),
    document.querySelector('.main'),
    document.querySelector('.map-panel'),
    document.querySelector('.filter-sidebar'),
    document.querySelector('.tab-home')
  ].filter(el => el !== null);

  mainElements.forEach(element => {
    element.addEventListener('scroll', (e) => {
      hideNavOnScroll(e.target.scrollTop);
    }, { passive: true });
  });
}, 100);
</script>
</body>
</html>
