<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Linx – B2B Marketplace</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#f8f9ff;--surface:#ffffff;--nav:#0f172a;
      --primary:#f97316;--primary-dark:#ea580c;--accent:#1e3a8a;
      --gold:#f59e0b;--gold-light:#fef3c7;--green:#10b981;
      --red:#ef4444;--text:#0f172a;--muted:#64748b;
      --border:#e0e7ff;--radius:10px;
      --shadow:0 2px 12px rgba(15,23,42,.08);
      --shadow-lg:0 8px 32px rgba(15,23,42,.15);
      --orange-light:#fff7ed;--orange-mid:#ffedd5;--orange-border:#fed7aa
    }
    body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);height:100vh;display:flex;flex-direction:column;overflow:hidden}

    /* ── NAV ── */
    nav{background:var(--nav);padding:0;height:170px;display:flex;align-items:stretch;flex-direction:row;flex-wrap:wrap;flex-shrink:0;box-shadow:0 2px 8px rgba(0,0,0,.3);position:relative;z-index:200;transition:all 0.3s ease;max-height:170px;overflow:hidden}
    nav.scrolled{max-height:0;height:0}
    .nav-links{display:flex;gap:2px;flex:1 1 auto;padding:12px 22px;align-items:center;background:var(--nav);border-bottom:1px solid rgba(30,58,138,.2)}
    .nav-link{color:#94a3b8;font-size:13px;font-weight:500;padding:5px 12px;border-radius:6px;cursor:pointer;text-decoration:none;transition:all .2s;white-space:nowrap}
    .nav-link:hover{color:#fff;background:rgba(255,255,255,.07)}
    .nav-link.active{color:#fff;background:rgba(249,115,22,.28);border-bottom:2px solid #f97316}
    .nav-right{display:flex;align-items:center;gap:9px;padding:12px 22px;background:var(--nav);flex-shrink:0;border-bottom:1px solid rgba(30,58,138,.2);position:relative;z-index:100}
    .nav-banner{flex:1 1 100%;display:flex;align-items:stretch;position:relative;overflow:hidden;gap:20px;padding:10px 30px;align-items:center;max-height:150px}
    .nav-banner > svg{flex:1;min-width:600px}
    .banner-video{flex:1;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
    .banner-video video{width:100%;height:100%;object-fit:cover;display:block}
    .banner-content{display:flex;align-items:center;justify-content:flex-start;flex-shrink:0;z-index:2;min-width:320px}
    .banner-text{color:#fff;max-width:300px}
    .btn-nav{background:var(--primary);color:#fff;border:none;border-radius:7px;padding:7px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:background .2s}
    .btn-nav:hover{background:var(--primary-dark)}
    .avatar{width:32px;height:32px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;cursor:pointer}

    /* ── LANGUAGE SWITCHER ── */
    .lang-switcher{position:relative;z-index:1001;overflow:visible}
    .lang-btn{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;border-radius:7px;padding:5px 11px;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;transition:background .2s;white-space:nowrap}
    .lang-btn:hover{background:rgba(255,255,255,.18)}
    .lang-btn .arrow{font-size:9px;opacity:.7;transition:transform .2s}
    .lang-btn.open .arrow{transform:rotate(180deg)}
    .lang-menu{position:fixed;background:var(--surface);border-radius:10px;box-shadow:var(--shadow-lg);border:1px solid var(--border);overflow:hidden;display:none;min-width:148px;z-index:9999}
    .lang-menu.open{display:block}
    .lang-opt{padding:9px 14px;font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:9px;transition:background .15s;color:var(--text)}
    .lang-opt:hover{background:var(--bg)}
    .lang-opt.active{background:var(--orange-light);color:var(--primary);font-weight:700}
    .lang-opt .flag{font-size:16px}

    /* ── SEARCH BAR ── */
    .search-bar{background:var(--surface);border-bottom:1px solid var(--border);padding:8px 18px;display:flex;align-items:center;gap:9px;flex-shrink:0;box-shadow:var(--shadow)}
    .sg{display:flex;align-items:center;gap:7px;background:var(--bg);border:1.5px solid var(--border);border-radius:8px;padding:6px 10px;transition:border-color .2s}
    .sg:focus-within{border-color:var(--primary)}
    .sg.flex1{flex:1}
    .sg .ico{font-size:14px;color:var(--muted)}
    .sg input{border:none;background:transparent;outline:none;font-size:13px;color:var(--text);width:100%;font-family:inherit}
    .sg input::placeholder{color:var(--muted)}
    .btn-search{background:var(--primary);color:#fff;border:none;border-radius:8px;padding:8px 18px;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;transition:background .2s}
    .btn-search:hover{background:var(--primary-dark)}

    /* ── MAIN LAYOUT ── */
    .main{display:flex;flex:1;overflow:hidden;position:relative;z-index:1}

    /* ── FILTER SIDEBAR ── */
    .filter-sidebar{width:268px;min-width:248px;background:var(--surface);border-right:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column;flex-shrink:0;border-top:3px solid var(--primary)}
    .filter-sidebar::-webkit-scrollbar{width:4px}
    .filter-sidebar::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
    .filter-header{padding:14px 16px 12px;display:flex;justify-content:space-between;align-items:center;border-bottom:2px solid var(--primary);background:var(--surface);position:sticky;top:0;z-index:10}
    .filter-title-main{font-size:15px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:6px}
    .btn-clear{font-size:11px;color:var(--primary);background:var(--orange-light);border:none;cursor:pointer;font-weight:700;padding:4px 9px;border-radius:6px;transition:all .15s}
    .btn-clear:hover{background:var(--primary);color:#fff}
    .filter-result{padding:9px 16px;font-size:12px;color:var(--muted);background:var(--bg);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:4px}
    .filter-result strong{color:var(--text);font-size:15px;font-weight:800}
    .filter-section{border-bottom:1px solid var(--border);padding:13px 16px}
    .filter-section-title{font-size:10.5px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin-bottom:10px}
    .filter-opt{display:flex;align-items:center;gap:8px;padding:4px 4px;cursor:pointer;border-radius:6px;transition:background .15s}
    .filter-opt:hover{background:var(--bg)}
    .filter-opt input[type=checkbox],.filter-opt input[type=radio]{width:15px;height:15px;accent-color:var(--primary);cursor:pointer;flex-shrink:0}
    .filter-opt label{font-size:12.5px;color:var(--text);cursor:pointer;flex:1;display:flex;align-items:center;gap:5px;line-height:1.3}
    .fcount{font-size:10.5px;color:var(--muted);background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:1px 6px;margin-left:auto;flex-shrink:0;font-weight:600}
    .sector-ico{width:13px;height:13px;color:var(--muted);flex-shrink:0;stroke-width:2}
    .filter-opt input:checked ~ label .sector-ico{color:var(--primary)}
    .rating-stars-f{color:var(--gold);font-size:12px;letter-spacing:-0.5px}
    .sort-opt{display:flex;align-items:center;gap:8px;padding:4px 4px;cursor:pointer;border-radius:6px;transition:background .15s}
    .sort-opt:hover{background:var(--bg)}
    .sort-opt input{width:15px;height:15px;accent-color:var(--primary);cursor:pointer;flex-shrink:0}
    .sort-opt label{font-size:12.5px;color:var(--text);cursor:pointer}
    .radius-section{border-bottom:1px solid var(--border);padding:13px 16px}
    .radius-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
    .radius-label{font-size:10.5px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;display:flex;align-items:center;gap:6px}
    .radius-value{font-size:16px;font-weight:800;color:#fff;background:linear-gradient(135deg,#f97316,#ea580c);padding:4px 12px;border-radius:8px;box-shadow:0 2px 8px rgba(249,115,22,.3)}
    .radius-slider{width:100%;accent-color:var(--primary);margin-bottom:6px;cursor:pointer;height:5px}
    .radius-slider::-webkit-slider-thumb{width:18px;height:18px;border-radius:50%;background:linear-gradient(135deg,#f97316,#ea580c);border:2px solid #fff;box-shadow:0 2px 8px rgba(249,115,22,.4);cursor:pointer}
    .radius-slider::-moz-range-thumb{width:18px;height:18px;border-radius:50%;background:linear-gradient(135deg,#f97316,#ea580c);border:2px solid #fff;box-shadow:0 2px 8px rgba(249,115,22,.4);cursor:pointer}
    .radius-marks{display:flex;justify-content:space-between;font-size:10px;color:var(--muted)}
    .tags-section{padding:13px 16px}
    .tags-section-title{font-size:10.5px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin-bottom:9px}
    .tags-cloud{display:flex;flex-wrap:wrap;gap:5px;max-height:160px;overflow-y:auto}
    .tags-cloud::-webkit-scrollbar{width:3px}
    .tags-cloud::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
    .tag-pill{border:1.5px solid var(--border);background:var(--bg);color:var(--muted);border-radius:15px;padding:3px 10px;font-size:10.5px;font-weight:500;cursor:pointer;transition:all .15s;white-space:nowrap}
    .tag-pill:hover{border-color:var(--primary);color:var(--primary)}
    .tag-pill.active{background:var(--primary);border-color:var(--primary);color:#fff}

    /* ── HIERARCHICAL FILTERS ── */
    .sector-filter-container{display:flex;flex-direction:column;gap:0}

    /* Level 1: Main Groups */
    .sector-category{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--bg);border-radius:7px;cursor:pointer;transition:all .15s;margin-bottom:6px;border:1.5px solid transparent;font-weight:600}
    .sector-category:hover{background:var(--orange-light);border-color:var(--primary)}
    .sector-category.open{background:var(--orange-light);border-color:var(--primary)}
    .sector-cat-icon{width:20px;height:20px;color:var(--muted);flex-shrink:0;transition:color .15s;display:flex;align-items:center;justify-content:center}
    .sector-category:hover .sector-cat-icon{color:var(--primary)}
    .sector-category.open .sector-cat-icon{color:var(--primary)}
    .sector-cat-label{font-size:12px;font-weight:600;color:var(--text);flex:1}
    .sector-cat-arrow{font-size:10px;color:var(--muted);transition:transform .2s;flex-shrink:0;font-weight:400}
    .sector-category.open .sector-cat-arrow{transform:rotate(180deg)}

    /* Level 2 & 3: Subcategories */
    .sector-subcats{display:none;flex-direction:column;gap:2px;padding-left:8px;margin-bottom:4px}
    .sector-subcats.show{display:flex}

    .sector-subcat{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;cursor:pointer;transition:all .15s;font-size:11px}
    .sector-subcat:hover{background:var(--bg)}
    .sector-subcat input[type=checkbox]{width:14px;height:14px;accent-color:var(--primary);cursor:pointer;flex-shrink:0}
    .sector-subcat label{color:var(--text);cursor:pointer;font-size:11px;flex:1;display:flex;align-items:center;gap:6px}
    .sector-subcat input[type=checkbox]:checked ~ label{color:var(--primary);font-weight:600}
    .sector-subcat .fcount{margin-left:auto;flex-shrink:0;font-size:10px;color:var(--muted);background:var(--bg);padding:2px 6px;border-radius:6px}

    /* ── MAP ── */
    .map-panel{flex:1;position:relative;overflow:hidden}
    #map{width:100%;height:100%}
    .map-info-box{position:absolute;top:12px;left:12px;background:var(--surface);border-radius:var(--radius);padding:7px 12px;box-shadow:var(--shadow);font-size:12px;color:var(--muted);display:flex;align-items:center;gap:7px;z-index:1000;pointer-events:none}
    .live-dot{width:8px;height:8px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}

    /* Route styling */
    .route-line{stroke:var(--primary);stroke-width:4;stroke-opacity:.8;stroke-dasharray:5,5;animation:route-pulse 2s infinite}
    @keyframes route-pulse{0%{stroke-opacity:.6}50%{stroke-opacity:.95}100%{stroke-opacity:.6}}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}

    .btn-register-now{background:var(--primary);color:#fff;border:none;border-radius:9px;padding:10px 22px;font-size:13px;font-weight:700;cursor:pointer;transition:background .2s;display:inline-flex;align-items:center;gap:7px}
    .btn-register-now:hover{background:var(--primary-dark)}

    /* ── DETAIL PANEL ── */
    .detail-panel{position:fixed;top:170px;right:-440px;width:418px;height:calc(100vh - 170px);background:var(--surface);box-shadow:var(--shadow-lg);z-index:200;display:flex;flex-direction:column;transition:right .3s ease, top .3s ease, height .3s ease;border-left:1px solid var(--border)}
    .detail-panel.open{right:0}
    .dp-header{background:var(--nav);padding:14px 16px;display:flex;align-items:flex-start;gap:11px;flex-shrink:0}
    .dp-logo{width:48px;height:48px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:22px;color:#fff;flex-shrink:0}
    .dp-name{font-size:15px;font-weight:800;color:#fff;margin-bottom:3px}
    .dp-sub{font-size:11px;color:#94a3b8}
    .dp-info{flex:1}
    .dp-close{background:rgba(255,255,255,.1);border:none;color:#fff;width:28px;height:28px;border-radius:6px;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s}
    .dp-close:hover{background:rgba(255,255,255,.2)}
    .dp-body{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:14px}
    .dp-body::-webkit-scrollbar{width:4px}
    .dp-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
    .dp-section-title{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:7px}
    .dp-address{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--muted);background:var(--bg);padding:8px 11px;border-radius:8px}
    .rating-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px}
    .rating-axis{background:var(--bg);border-radius:8px;padding:9px}
    .axis-label{font-size:11px;color:var(--muted);margin-bottom:4px}
    .axis-bar{height:5px;background:var(--border);border-radius:3px;overflow:hidden;margin-bottom:3px}
    .axis-fill{height:100%;border-radius:3px;background:var(--primary)}
    .axis-val{font-size:12px;font-weight:700}
    .channel-grid{display:flex;flex-direction:column;gap:7px}
    .channel-btn{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:9px;border:1.5px solid transparent;cursor:pointer;transition:all .2s}
    .ch-icon{width:32px;height:32px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
    .ch-name{font-size:13px;font-weight:700}.ch-desc{font-size:11px;opacity:.7}.ch-info{flex:1}
    .channel-btn.wa{background:#f0fdf4;border-color:#bbf7d0;color:#15803d}.channel-btn.wa:hover{background:#16a34a;color:#fff;border-color:#16a34a}
    .channel-btn.wa .ch-icon{background:#16a34a;color:#fff}
    .channel-btn.chat{background:var(--orange-light);border-color:var(--orange-border);color:#c2410c}.channel-btn.chat:hover{background:var(--primary);color:#fff;border-color:var(--primary)}
    .channel-btn.chat .ch-icon{background:var(--primary);color:#fff}
    .channel-btn.email{background:var(--bg);border-color:var(--border);color:var(--text)}.channel-btn.email:hover{background:var(--text);color:#fff;border-color:var(--text)}
    .channel-btn.email .ch-icon{background:#475569;color:#fff}
    .review-item{border-bottom:1px solid var(--border);padding-bottom:10px}
    .review-item:last-child{border-bottom:none}
    .review-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px}
    .review-name{font-size:12px;font-weight:700}.review-date{font-size:11px;color:var(--muted)}
    .review-text{font-size:12px;color:var(--muted);line-height:1.5}
    .stars{color:var(--gold);font-size:12px;letter-spacing:-1px}
    .badge{display:inline-flex;align-items:center;gap:3px;font-size:10px;font-weight:700;border-radius:5px;padding:2px 6px}
    .badge-gold{background:var(--gold-light);color:#92400e}
    .badge-blue{background:var(--orange-mid);color:#c2410c}
    .badge-green{background:#dcfce7;color:#166534}
    .card-tags{display:flex;flex-wrap:wrap;gap:4px}
    .tag{background:var(--orange-light);color:#c2410c;font-size:10.5px;font-weight:500;padding:2px 7px;border-radius:20px}

    /* ── CHAT WIDGET ── */
    .chat-widget{position:fixed;bottom:20px;right:20px;z-index:300}
    .chat-fab{width:50px;height:50px;background:var(--primary);border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:0 4px 20px rgba(37,99,235,.4);transition:all .2s;color:#fff}
    .chat-fab:hover{transform:scale(1.08);background:var(--primary-dark)}
    .chat-notif{position:absolute;top:-3px;right:-3px;width:18px;height:18px;background:var(--red);border-radius:50%;font-size:10px;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:center;border:2px solid var(--surface)}
    .chat-box{position:absolute;bottom:63px;right:0;width:320px;background:var(--surface);border-radius:14px;box-shadow:var(--shadow-lg);display:none;flex-direction:column;overflow:hidden;border:1px solid var(--border)}
    .chat-box.open{display:flex}
    .chat-head{background:var(--primary);padding:10px 14px;display:flex;align-items:center;gap:9px}
    .chat-head-avatar{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:14px}
    .chat-head-name{color:#fff;font-size:13px;font-weight:700}.chat-head-status{color:#fed7aa;font-size:11px}.chat-head-info{flex:1}
    .chat-head-close{background:none;border:none;color:rgba(255,255,255,.7);font-size:16px;cursor:pointer}
    .chat-msgs{padding:12px;flex:1;display:flex;flex-direction:column;gap:8px;min-height:190px;max-height:270px;overflow-y:auto;background:var(--bg)}
    .msg{max-width:75%}.msg-in{align-self:flex-start}.msg-out{align-self:flex-end}
    .msg-bubble{padding:7px 10px;border-radius:11px;font-size:12px;line-height:1.45}
    .msg-in .msg-bubble{background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:3px 11px 11px 11px}
    .msg-out .msg-bubble{background:var(--primary);color:#fff;border-radius:11px 3px 11px 11px}
    .msg-time{font-size:10px;color:var(--muted);margin-top:2px}
    .msg-out .msg-time{text-align:right}
    .msg-file{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.15);border-radius:6px;padding:4px 7px;margin-top:3px;font-size:11px}
    .chat-input-bar{padding:8px;border-top:1px solid var(--border);display:flex;gap:6px;align-items:center}
    .chat-input{flex:1;border:1.5px solid var(--border);border-radius:8px;padding:7px 10px;font-size:12px;outline:none;transition:border-color .2s;font-family:inherit}
    .chat-input:focus{border-color:var(--primary)}
    .chat-send{background:var(--primary);border:none;border-radius:8px;width:32px;height:32px;color:#fff;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center}
    .chat-send:hover{background:var(--primary-dark)}
    .chat-attach{background:var(--bg);border:1.5px solid var(--border);border-radius:8px;width:32px;height:32px;color:var(--muted);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center}

    /* ── MODALS ── */
    .overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:400;display:none;align-items:center;justify-content:center}
    .overlay.open{display:flex}
    .modal{background:var(--surface);border-radius:13px;padding:24px;width:500px;max-width:96vw;box-shadow:var(--shadow-lg);max-height:92vh;overflow-y:auto}
    .modal-sm{width:440px}
    .modal-title{font-size:16px;font-weight:800;margin-bottom:5px}
    .modal-sub{font-size:12px;color:var(--muted);margin-bottom:16px;line-height:1.5}
    .form-row{margin-bottom:12px}
    .form-row label{display:block;font-size:12px;font-weight:600;margin-bottom:4px;color:var(--text)}
    .form-row input,.form-row textarea,.form-row select{width:100%;border:1.5px solid var(--border);border-radius:8px;padding:8px 10px;font-size:13px;outline:none;transition:border-color .2s;font-family:inherit;color:var(--text)}
    .form-row input:focus,.form-row textarea:focus,.form-row select:focus{border-color:var(--primary)}
    .form-row textarea{resize:vertical;min-height:80px}
    .req{color:var(--red)}
    .form-hint{font-size:11px;color:var(--muted);margin-top:3px}
    .form-grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:6px}
    .btn-cancel{background:var(--bg);border:1.5px solid var(--border);color:var(--muted);border-radius:8px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s}
    .btn-cancel:hover{border-color:var(--muted)}
    .btn-submit{background:var(--primary);color:#fff;border:none;border-radius:8px;padding:8px 20px;font-size:13px;font-weight:600;cursor:pointer;transition:background .2s}
    .btn-submit:hover{background:var(--primary-dark)}

    /* ── TOAST ── */
    .toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:var(--nav);color:#fff;padding:9px 20px;border-radius:28px;font-size:13px;font-weight:500;box-shadow:var(--shadow-lg);display:none;z-index:500;animation:fadeUp .3s ease}
    .toast.show{display:block}
    @keyframes fadeUp{from{opacity:0;transform:translateX(-50%) translateY(8px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

    /* ── Leaflet ── */
    .leaflet-control-attribution{font-size:10px!important}
    .leaflet-popup-content-wrapper{border-radius:9px!important;box-shadow:var(--shadow-lg)!important}
    .leaflet-popup-content{font-size:13px!important;line-height:1.5!important}

    /* ── LUCIDE ICONS ── */
    [data-lucide]{display:inline-block;vertical-align:middle;flex-shrink:0;stroke-width:2}
    /* Nav */
    .nav-link{display:inline-flex;align-items:center;gap:5px}
    .nav-link [data-lucide]{width:14px;height:14px}
    .btn-nav{display:inline-flex;align-items:center;gap:6px}
    .btn-nav [data-lucide]{width:13px;height:13px}
    /* Filter sidebar */
    .filter-title-main{display:flex;align-items:center;gap:7px}
    .filter-title-main [data-lucide]{width:15px;height:15px;color:var(--primary)}
    .filter-section-title{display:flex;align-items:center;gap:6px}
    .filter-section-title [data-lucide]{width:12px;height:12px}
    .tags-section-title{display:flex;align-items:center;gap:6px}
    .tags-section-title [data-lucide]{width:12px;height:12px}
    .radius-label{display:flex;align-items:center;gap:5px}
    .radius-label [data-lucide]{width:12px;height:12px}
    /* Search bar */
    .ico-svg{flex-shrink:0;color:var(--muted)}
    .ico-svg[data-lucide]{width:15px;height:15px}
    .btn-search{display:inline-flex;align-items:center;gap:6px}
    .btn-search [data-lucide]{width:14px;height:14px}
    .sg-loc{position:relative}
    .btn-locate{background:none;border:none;cursor:pointer;padding:2px 5px;color:var(--muted);border-radius:5px;display:flex;align-items:center;transition:color .2s;flex-shrink:0}
    .btn-locate:hover{color:var(--primary)}
    .btn-locate [data-lucide]{width:15px;height:15px}
    .btn-locate.locating [data-lucide]{animation:iconSpin 1s linear infinite;color:var(--primary)}
    @keyframes iconSpin{to{transform:rotate(360deg)}}
    /* Detail panel */
    .dp-section-title{display:flex;align-items:center;gap:6px}
    .dp-section-title [data-lucide]{width:12px;height:12px}
    .ch-icon [data-lucide]{width:18px;height:18px}
    .ch-arrow[data-lucide]{width:14px;height:14px;color:var(--muted)}
    /* Empty state */
    .es-icon{margin-bottom:12px;display:flex;justify-content:center}
    .es-lucide{width:54px;height:54px;color:var(--border);stroke-width:1.2}
    /* Buttons */
    .btn-register-now{display:inline-flex;align-items:center;gap:7px}
    .btn-register-now [data-lucide]{width:15px;height:15px}
    .btn-submit{display:inline-flex;align-items:center;gap:7px;justify-content:center}
    .btn-submit [data-lucide]{width:14px;height:14px}
    /* Modal */
    .modal-title{display:flex;align-items:center;gap:9px}
    .modal-title [data-lucide]{width:18px;height:18px;color:var(--primary)}
    /* Chat */
    .chat-fab{display:flex;align-items:center;justify-content:center}
    .chat-fab [data-lucide]{width:22px;height:22px}
    /* Home page */
    .btn-hero-primary,.btn-hero-secondary{display:inline-flex;align-items:center;gap:8px}
    .btn-hero-primary [data-lucide],.btn-hero-secondary [data-lucide]{width:16px;height:16px}
    .step-icon{margin-bottom:12px;display:flex;justify-content:center}
    .step-lucide{width:32px;height:32px;color:var(--primary);stroke-width:1.5}
    .usecase-icon{margin-bottom:20px;display:flex;align-items:center;justify-content:center;width:85px;height:85px;border-radius:16px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));box-shadow:0 8px 24px rgba(249,115,22,.25);transition:all .3s;position:relative;overflow:hidden}
    .usecase-icon::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.1),rgba(255,255,255,0));border-radius:16px;pointer-events:none}
    .usecase-card:hover .usecase-icon{transform:translateY(-4px);box-shadow:0 12px 32px rgba(249,115,22,.35)}
    .uc-lucide{width:48px;height:48px;color:#fff;stroke-width:1.8;position:relative;z-index:1}

    /* B2B & B2C Card Variants */
    .usecase-b2b .usecase-icon{background:linear-gradient(135deg,#f97316,#ea580c)}
    .usecase-b2b .usecase-icon::before{background:linear-gradient(135deg,rgba(255,255,255,.12),rgba(255,255,255,0))}
    .usecase-b2b:hover .usecase-icon{box-shadow:0 12px 32px rgba(249,115,22,.35)}

    .usecase-b2c .usecase-icon{background:linear-gradient(135deg,#1e3a8a,#1e40af)}
    .usecase-b2c .usecase-icon::before{background:linear-gradient(135deg,rgba(255,255,255,.12),rgba(255,255,255,0))}
    .usecase-b2c:hover .usecase-icon{box-shadow:0 12px 32px rgba(30,58,138,.35)}

    /* ── HOME TAB ── */
    .tab-home{flex:1;overflow-y:auto;background:var(--bg);display:none;flex-direction:column}
    .tab-search{flex:1;display:flex;flex-direction:column;overflow:hidden}
    .home-hero{background:linear-gradient(135deg,#0f172a 0%,#1e3a8a 50%,#0f172a 100%);color:#fff;padding:60px 40px 52px;text-align:center;position:relative;overflow:hidden;flex-shrink:0}
    .home-hero::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 65% 35%,rgba(249,115,22,.18) 0%,transparent 60%),radial-gradient(ellipse at 25% 75%,rgba(30,58,138,.12) 0%,transparent 55%);pointer-events:none}
    .hero-label{font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:#f97316;margin-bottom:16px}
    .hero-title{font-size:40px;font-weight:900;line-height:1.12;margin-bottom:18px;letter-spacing:-.5px;position:relative;z-index:1}
    .hero-accent{background:linear-gradient(90deg,#f97316,#fb923c);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero-sub{font-size:16px;color:#94a3b8;max-width:580px;margin:0 auto 36px;line-height:1.65;position:relative;z-index:1}
    .hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;position:relative;z-index:1}
    .btn-hero-primary{background:linear-gradient(135deg,#f97316,#ea580c);color:#fff;border:none;border-radius:9px;padding:12px 26px;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;box-shadow:0 4px 18px rgba(249,115,22,.42)}
    .btn-hero-primary:hover{transform:translateY(-2px);box-shadow:0 7px 24px rgba(249,115,22,.55)}
    .btn-hero-secondary{background:rgba(255,255,255,.08);color:#fff;border:1px solid rgba(255,255,255,.18);border-radius:9px;padding:12px 26px;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s}
    .btn-hero-secondary:hover{background:rgba(249,115,22,.15);border-color:rgba(249,115,22,.4)}
    .home-content{max-width:1060px;margin:0 auto;padding:52px 32px 32px;width:100%}
    .home-section{margin-bottom:56px}
    .home-section-label{font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--primary);margin-bottom:8px}
    .home-section-title{font-size:24px;font-weight:800;color:var(--text);margin-bottom:12px;line-height:1.3}
    .home-section-sub{font-size:15px;color:var(--muted);line-height:1.7;max-width:700px;margin-bottom:28px}
    .usecase-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
    .usecase-card{border-radius:18px;padding:40px 32px;transition:all .3s;border:none;position:relative;overflow:hidden;display:flex;flex-direction:column;align-items:center;text-align:center;min-height:380px;justify-content:flex-start}
    .usecase-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(255,255,255,.15),transparent 60%);pointer-events:none;z-index:0}
    .usecase-card > *{position:relative;z-index:1}
    .usecase-card:hover{transform:translateY(-6px);box-shadow:0 20px 50px rgba(0,0,0,.15)}

    /* B2B Card */
    .usecase-b2b{background:linear-gradient(135deg,#fff7ed 0%,#ffedd5 100%);border:2px solid #fed7aa}
    .usecase-b2b .usecase-badge{background:linear-gradient(135deg,#f97316,#ea580c);color:#fff;padding:6px 14px;border-radius:20px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px;display:inline-block}

    /* B2C Card */
    .usecase-b2c{background:linear-gradient(135deg,#eff6ff 0%,#dbeafe 100%);border:2px solid #bfdbfe}
    .usecase-b2c .usecase-badge{background:linear-gradient(135deg,#1e3a8a,#1e40af);color:#fff;padding:6px 14px;border-radius:20px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px;display:inline-block}

    .usecase-icon{font-size:34px;margin-bottom:20px;display:flex;align-items:center;justify-content:center;width:100px;height:100px;border-radius:20px;box-shadow:0 12px 30px rgba(0,0,0,.15);position:relative;overflow:hidden}
    .usecase-icon::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 30%,rgba(255,255,255,.3),transparent 70%);pointer-events:none}
    .usecase-card:hover .usecase-icon{transform:scale(1.1) translateY(-4px)}
    .uc-lucide{width:56px;height:56px;stroke-width:1.6;position:relative;z-index:1}

    /* Custom SVG Icons */
    .usecase-custom-icon{width:120px;height:120px;margin-bottom:20px}
    .usecase-b2b .usecase-custom-icon{filter:drop-shadow(0 8px 20px rgba(249,115,22,.25))}
    .usecase-b2c .usecase-custom-icon{filter:drop-shadow(0 8px 20px rgba(30,58,138,.25))}
    .usecase-card:hover .usecase-custom-icon{filter:drop-shadow(0 12px 28px rgba(0,0,0,.25));transform:scale(1.08) translateY(-4px);transition:all .3s ease}

    .usecase-title{font-size:18px;font-weight:800;margin-bottom:12px;color:var(--text);letter-spacing:-.3px}
    .usecase-desc{font-size:14px;color:var(--text);line-height:1.7;opacity:.85}
    .house-intro{font-size:15px;color:var(--muted);line-height:1.7;margin-bottom:24px}
    .house-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin-bottom:22px}
    .house-card{background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:16px 14px;display:flex;align-items:flex-start;gap:11px;transition:all .2s;cursor:default}
    .house-card:hover{border-color:var(--primary);box-shadow:0 3px 14px rgba(249,115,22,.18);transform:translateY(-2px)}
    .house-card-icon{width:56px;height:56px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:var(--primary);background:linear-gradient(135deg,#fff7ed,#ffedd5);border-radius:12px;margin-top:2px;padding:4px}
    .house-card-icon svg{width:100%;height:100%;display:block}
    .house-card-name{font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px}
    .house-card-sub{font-size:11.5px;color:var(--muted);line-height:1.4}
    .house-cta-box{background:linear-gradient(135deg,#fff7ed,#ffedd5);border:1.5px solid #fed7aa;border-radius:13px;padding:22px 26px;display:flex;align-items:flex-start;gap:16px}
    .house-cta-ico{width:34px;height:34px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:var(--primary);margin-top:2px}
    .house-cta-ico [data-lucide]{width:30px;height:30px;stroke-width:1.5}
    .house-cta-text{font-size:14px;color:var(--text);line-height:1.7}
    .house-cta-text strong{color:var(--primary)}
    .steps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
    .step-card{background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:28px 22px;text-align:center;position:relative}
    .step-num{width:36px;height:36px;background:linear-gradient(135deg,#f97316,#ea580c);color:#fff;border-radius:50%;font-size:15px;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
    .step-icon{font-size:30px;margin-bottom:12px}
    .step-title{font-size:15px;font-weight:800;color:var(--text);margin-bottom:8px}
    .step-desc{font-size:13px;color:var(--muted);line-height:1.65}
    .step-connector{display:flex;align-items:center;justify-content:center;color:#cbd5e1;font-size:22px;position:absolute;top:50%;right:-14px;transform:translateY(-50%);z-index:2}
    .home-cta-bar{background:linear-gradient(135deg,#1e3a8a,#0f172a);border-radius:16px;padding:44px 40px;text-align:center;color:#fff;margin-bottom:48px;border:1px solid rgba(30,58,138,.3);box-shadow:0 0 40px rgba(30,58,138,.12)}
    .home-cta-title{font-size:24px;font-weight:900;margin-bottom:10px}
    .home-cta-sub{font-size:15px;color:#94a3b8;margin-bottom:28px;line-height:1.6}
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-banner">
    <div class="banner-content">
      <!-- LOGO LINX - Minimalista -->
      <svg width="50" height="50" viewBox="0 0 50 50" style="margin-right: 35px; flex-shrink: 0;">
        <!-- L com ponto conectando -->
        <text x="8" y="35" font-size="28" font-weight="900" fill="#f97316" font-family="Arial, sans-serif">L</text>
        <!-- Linha de conexão (representa link/conexão) -->
        <line x1="22" y1="15" x2="28" y2="15" stroke="#f97316" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Ponto de conexão -->
        <circle cx="25" cy="15" r="1.5" fill="#f97316"/>
        <!-- NX comprimido -->
        <text x="20" y="35" font-size="28" font-weight="900" fill="#fff" font-family="Arial, sans-serif">NX</text>
      </svg>

      <div class="banner-text">
        <h2 style="margin: 0; color: #fff; font-size: 15px; font-weight: 800; margin-bottom: 4px;">Encontre o Profissional<br/>ou Empresa Certo</h2>
        <p style="margin: 0; color: #cbd5e1; font-size: 11px; line-height: 1.3;">Conecte com profissionais e empresas. Sem intermediários.</p>
      </div>
    </div>
    <!-- ESPAÇO PARA PUBLICIDADE -->
    <div style="flex: 1; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(30,58,138,.1) 0%, rgba(249,115,22,.1) 100%); border-radius: 12px; margin: 0 20px; overflow: hidden;">
      <div style="text-align: center; color: #94a3b8; font-size: 14px; font-weight: 500;">
        <p style="margin: 0; margin-bottom: 8px;">📢 Espaço para Publicidade</p>
        <p style="margin: 0; font-size: 12px; opacity: 0.7;">Vídeo, Imagem ou Campanha Promocional</p>
      </div>
    </div>
  </div>
  <div class="nav-links">
    <a class="nav-link" href="#" data-tab="home" onclick="showTab('home')"><i data-lucide="home"></i><span data-i18n="navHome">Início</span></a>
    <a class="nav-link active" href="#" data-tab="search" onclick="showTab('search')"><i data-lucide="search"></i><span data-i18n="navSearch">Pesquisa</span></a>
    <a class="nav-link" href="#" data-tab="about" onclick="showTab('about')"><i data-lucide="info"></i><span data-i18n="navAbout">Sobre</span></a>
  </div>
  <div class="nav-right">
    <button class="btn-nav" id="btnRegisterNav" onclick="openRegister()"><i data-lucide="plus-circle"></i><span data-i18n="navRegister">Registar Empresa</span></button>

    <!-- LANGUAGE SWITCHER -->
    <div class="lang-switcher" id="langSwitcher">
      <button class="lang-btn" id="langBtn" onclick="toggleLangMenu()">
        <span id="langFlag">🇵🇹</span>
        <span id="langCode">PT</span>
        <span class="arrow">▾</span>
      </button>
      <div class="lang-menu" id="langMenu">
        <div class="lang-opt active" data-lang="pt" onclick="setLanguage('pt')">
          <span class="flag">🇵🇹</span> Português
        </div>
        <div class="lang-opt" data-lang="en" onclick="setLanguage('en')">
          <span class="flag">🇬🇧</span> English
        </div>
        <div class="lang-opt" data-lang="fr" onclick="setLanguage('fr')">
          <span class="flag">🇫🇷</span> Français
        </div>
      </div>
    </div>

    <div class="avatar">JM</div>
  </div>
</nav>

<!-- HOME TAB -->
<section id="tab-home" class="tab-home">
  <!-- HERO -->
  <div class="home-hero">
    <h1 class="hero-title">
      <span data-i18n="heroTitleMain">Ligue-se. Colabore. </span><span class="hero-accent" data-i18n="heroTitleAccent">Cresça.</span>
    </h1>
    <p class="hero-sub" data-i18n="heroSub">A Linx une empresas e particulares aos melhores fornecedores de serviços — de forma rápida, transparente e com total controlo.</p>
    <div class="hero-btns">
      <button class="btn-hero-primary" onclick="showTab('search')"><i data-lucide="compass"></i><span data-i18n="heroBtnSearch">Explorar Empresas</span></button>
      <button class="btn-hero-secondary" onclick="openRegister()"><i data-lucide="building-2"></i><span data-i18n="heroBtnRegister">Registar a minha Empresa</span></button>
    </div>
  </div>

  <div class="home-content">

    <!-- WHAT IS LINX -->
    <div class="home-section">
      <div class="home-section-label" data-i18n="whatLabel">O que é a Linx</div>
      <h2 class="home-section-title" data-i18n="whatTitle">Uma plataforma para todos</h2>
      <p class="home-section-sub" data-i18n="whatSub">A Linx foi criada para simplificar a forma como clientes e fornecedores se encontram. Seja uma empresa à procura de parceiros estratégicos, seja um particular que precisa de um serviço rápido — a Linx conecta-os a especialistas de confiança, com avaliações verificadas e contacto direto.</p>
      <div class="usecase-grid">
        <div class="usecase-card usecase-b2b">
          <div class="usecase-badge">Para Empresas</div>
          <svg class="usecase-custom-icon" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <circle cx="100" cy="100" r="95" fill="rgba(249,115,22,.08)" stroke="#fed7aa" stroke-width="2"/>
            <rect x="25" y="70" width="45" height="70" fill="#f97316" rx="4"/>
            <rect x="32" y="78" width="10" height="12" fill="#fff7ed" rx="1"/><rect x="45" y="78" width="10" height="12" fill="#fff7ed" rx="1"/>
            <rect x="32" y="96" width="10" height="12" fill="#fff7ed" rx="1"/><rect x="45" y="96" width="10" height="12" fill="#fff7ed" rx="1"/>
            <rect x="32" y="114" width="10" height="12" fill="#fff7ed" rx="1"/><rect x="45" y="114" width="10" height="12" fill="#fff7ed" rx="1"/>
            <polygon points="25,70 52.5,55 80,70" fill="#ea580c"/>
            <circle cx="60" cy="85" r="3" fill="#f97316" stroke="#fff" stroke-width="1"/>
            <circle cx="100" cy="100" r="5" fill="#f97316" stroke="#fff" stroke-width="2"/>
            <circle cx="140" cy="85" r="3" fill="#f97316" stroke="#fff" stroke-width="1"/>
            <line x1="65" y1="85" x2="95" y2="100" stroke="#f97316" stroke-width="2" stroke-dasharray="3,2" opacity="0.7"/>
            <line x1="100" y1="105" x2="135" y2="85" stroke="#f97316" stroke-width="2" stroke-dasharray="3,2" opacity="0.7"/>
            <line x1="65" y1="85" x2="140" y2="85" stroke="#f97316" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.5"/>
            <rect x="130" y="70" width="45" height="70" fill="#f97316" rx="4"/>
            <rect x="137" y="78" width="10" height="12" fill="#fff7ed" rx="1"/><rect x="150" y="78" width="10" height="12" fill="#fff7ed" rx="1"/>
            <rect x="137" y="96" width="10" height="12" fill="#fff7ed" rx="1"/><rect x="150" y="96" width="10" height="12" fill="#fff7ed" rx="1"/>
            <rect x="137" y="114" width="10" height="12" fill="#fff7ed" rx="1"/><rect x="150" y="114" width="10" height="12" fill="#fff7ed" rx="1"/>
            <polygon points="130,70 157.5,55 185,70" fill="#ea580c"/>
            <circle cx="100" cy="100" r="8" fill="none" stroke="#f97316" stroke-width="1.5"/>
            <line x1="100" y1="96" x2="100" y2="104" stroke="#f97316" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="96" y1="100" x2="104" y2="100" stroke="#f97316" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <div class="usecase-title" data-i18n="uc1Title">Empresa para Empresa</div>
          <div class="usecase-title" style="font-size:14px;font-weight:400;color:#f97316;margin-bottom:12px;margin-top:-8px">(B2B)</div>
          <div class="usecase-desc" data-i18n="uc1Desc">Conecta empresas a fornecedores, parceiros estratégicos e subcontratados especializados. Ideal para projectos exigentes, contratos a longo prazo e colaborações continuadas de qualidade.</div>
        </div>

        <div class="usecase-card usecase-b2c">
          <div class="usecase-badge">Para Particulares</div>
          <svg class="usecase-custom-icon" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <circle cx="100" cy="100" r="95" fill="rgba(30,58,138,.08)" stroke="#bfdbfe" stroke-width="2"/>
            <rect x="35" y="85" width="90" height="70" fill="#1e3a8a" rx="6"/>
            <polygon points="35,85 80,40 125,85" fill="#1e40af" stroke="#0f172a" stroke-width="1"/>
            <rect x="80" y="110" width="20" height="35" fill="#0f172a" rx="2"/>
            <circle cx="98" cy="127" r="1.5" fill="#fbbf24"/>
            <rect x="45" y="95" width="14" height="14" fill="#60a5fa" rx="1"/>
            <line x1="52" y1="95" x2="52" y2="109" stroke="#1e3a8a" stroke-width="0.5"/><line x1="45" y1="102" x2="59" y2="102" stroke="#1e3a8a" stroke-width="0.5"/>
            <rect x="106" y="95" width="14" height="14" fill="#60a5fa" rx="1"/>
            <line x1="113" y1="95" x2="113" y2="109" stroke="#1e3a8a" stroke-width="0.5"/><line x1="106" y1="102" x2="120" y2="102" stroke="#1e3a8a" stroke-width="0.5"/>
            <rect x="110" y="50" width="8" height="20" fill="#0f172a"/>
            <rect x="109" y="48" width="10" height="4" fill="#0f172a"/>
            <g transform="translate(25, 100)"><path d="M 5 8 Q 3 5 2 3 L 8 0 Q 9 2 10 4 L 14 8" fill="none" stroke="#1e40af" stroke-width="1.2" stroke-linecap="round"/><circle cx="12" cy="8" r="2" fill="#1e40af"/></g>
            <g transform="translate(140, 100)"><rect x="2" y="0" width="3" height="8" fill="#1e40af"/><ellipse cx="3.5" cy="10" rx="3" ry="2" fill="#1e40af"/><line x1="3.5" y1="8" x2="3.5" y2="13" stroke="#1e40af" stroke-width="0.8"/></g>
            <g transform="translate(25, 140)"><rect x="6" y="2" width="2" height="9" fill="#1e40af"/><rect x="3" y="0" width="8" height="4" fill="#1e40af" rx="1"/><circle cx="7" cy="11" r="1.5" fill="#1e40af"/></g>
            <g transform="translate(140, 140)"><circle cx="3.5" cy="4" r="3" fill="none" stroke="#1e40af" stroke-width="1"/><line x1="1.5" y1="7.5" x2="5.5" y2="7.5" stroke="#1e40af" stroke-width="1" stroke-linecap="round"/><line x1="2" y1="9" x2="5" y2="9" stroke="#1e40af" stroke-width="0.8" stroke-linecap="round"/><line x1="2.5" y1="10" x2="4.5" y2="10" stroke="#1e40af" stroke-width="0.8" stroke-linecap="round"/></g>
          </svg>
          <div class="usecase-title" data-i18n="uc2Title">Particular para Empresa</div>
          <div class="usecase-title" style="font-size:14px;font-weight:400;color:#1e3a8a;margin-bottom:12px;margin-top:-8px">(B2C)</div>
          <div class="usecase-desc" data-i18n="uc2Desc">Para quem precisa de serviços profissionais para uso pessoal ou doméstico. Reparações, renovações, instalações — tudo simples, rápido e direto, sem intermediários.</div>
        </div>
      </div>
    </div>

    <!-- HOUSE EXAMPLE -->
    <div class="home-section">
      <div class="home-section-label" data-i18n="houseLabel">Exemplo prático</div>
      <h2 class="home-section-title" data-i18n="houseTitle">Construir uma casa? Encontre todos os especialistas</h2>
      <p class="house-intro" data-i18n="houseIntro">A construção de uma casa envolve dezenas de especialidades diferentes. Com a Linx, consegue identificar e contactar empresas para cada fase da obra — tudo numa só plataforma.</p>
      <div class="house-grid" id="houseGrid"><!-- rendered by JS --></div>
      <div class="house-cta-box">
        <span class="house-cta-ico"><i data-lucide="lightbulb"></i></span>
        <div class="house-cta-text" id="houseCtaText">Com a Linx, faça uma <strong>pesquisa rápida por filtros</strong> para cada especialidade, compare avaliações e <strong>peça orçamento a várias empresas</strong> — tudo num só lugar, sem telefonemas nem intermediários.</div>
      </div>
    </div>

    <!-- HOW IT WORKS -->
    <div class="home-section">
      <div class="home-section-label" data-i18n="stepsLabel">Como funciona</div>
      <h2 class="home-section-title" data-i18n="stepsTitle">Em 3 passos simples</h2>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">1</div>
          <div class="step-icon"><i data-lucide="search" class="step-lucide"></i></div>
          <div class="step-title" data-i18n="step1Title">Pesquise com filtros</div>
          <div class="step-desc" data-i18n="step1Desc">Filtre por setor, localização, avaliação e especialidade. O mapa atualiza em tempo real com as empresas que correspondem.</div>
          <div class="step-connector">›</div>
        </div>
        <div class="step-card">
          <div class="step-num">2</div>
          <div class="step-icon"><i data-lucide="clipboard-list" class="step-lucide"></i></div>
          <div class="step-title" data-i18n="step2Title">Compare empresas</div>
          <div class="step-desc" data-i18n="step2Desc">Veja perfis detalhados, avaliações multidimensionais em qualidade, prazos, comunicação e preço, e especialidades de cada empresa.</div>
          <div class="step-connector">›</div>
        </div>
        <div class="step-card">
          <div class="step-num">3</div>
          <div class="step-icon"><i data-lucide="send" class="step-lucide"></i></div>
          <div class="step-title" data-i18n="step3Title">Peça orçamentos</div>
          <div class="step-desc" data-i18n="step3Desc">Contacte diretamente via email formal, chat interno em tempo real ou WhatsApp. Sem intermediários, sem demoras.</div>
        </div>
      </div>
    </div>

    <!-- CTA FINAL -->
    <div class="home-cta-bar">
      <div class="home-cta-title" data-i18n="ctaTitle">Pronto para começar?</div>
      <div class="home-cta-sub" data-i18n="ctaSub">Explore as empresas disponíveis ou registe a sua empresa na Linx hoje mesmo.</div>
      <div class="hero-btns">
        <button class="btn-hero-primary" onclick="showTab('search')"><i data-lucide="compass"></i><span data-i18n="heroBtnSearch">Explorar Empresas</span></button>
        <button class="btn-hero-secondary" onclick="openRegister()"><i data-lucide="building-2"></i><span data-i18n="heroBtnRegister">Registar a minha Empresa</span></button>
      </div>
    </div>

  </div>
</section>

<!-- SEARCH TAB -->
<div id="tab-search" class="tab-search">

<!-- SEARCH BAR -->
<div class="search-bar">
  <div class="sg sg-loc">
    <i data-lucide="map-pin" class="ico-svg"></i>
    <input id="locInput" type="text" value="Lisboa, Portugal"/>
    <button class="btn-locate" id="btnLocate" onclick="detectUserLocation()" title="Usar localização atual">
      <i data-lucide="crosshair"></i>
    </button>
  </div>
  <div class="sg flex1">
    <i data-lucide="search" class="ico-svg"></i>
    <input id="kwInput" type="text" oninput="applyFilters()"/>
  </div>
  <button class="btn-search" id="btnSearch" onclick="applyFilters();showToast(t('searchUpdated'))">
    <i data-lucide="search"></i><span data-i18n="btnSearch">Pesquisar</span>
  </button>
</div>

<!-- MAIN -->
<div class="main">

  <!-- FILTER SIDEBAR -->
  <div class="filter-sidebar">
    <div class="filter-header">
      <div class="filter-title-main"><i data-lucide="sliders-horizontal"></i><span data-i18n="filterTitle">Filtros</span></div>
      <button class="btn-clear" onclick="clearAllFilters()" data-i18n="clearAll">Limpar Tudo</button>
    </div>

    <div class="filter-result">
      <strong id="countNum">0</strong>&nbsp;<span data-i18n="companiesFound">empresas encontradas</span>
    </div>

    <!-- SORT -->
    <div class="filter-section">
      <div class="filter-section-title"><i data-lucide="arrow-up-down"></i><span data-i18n="sortBy">Ordenar Por</span></div>
      <div class="sort-opt">
        <input type="radio" name="sort" id="sortRating" value="rating" checked onchange="applyFilters()"/>
        <label for="sortRating" data-i18n="sortRating">Melhor Avaliação</label>
      </div>
      <div class="sort-opt">
        <input type="radio" name="sort" id="sortReviews" value="reviews" onchange="applyFilters()"/>
        <label for="sortReviews" data-i18n="sortReviews">Mais Avaliados</label>
      </div>
      <div class="sort-opt">
        <input type="radio" name="sort" id="sortName" value="name" onchange="applyFilters()"/>
        <label for="sortName" data-i18n="sortName">Nome A–Z</label>
      </div>
    </div>

    <!-- SECTOR -->
    <div class="filter-section">
      <div class="filter-section-title"><i data-lucide="building-2"></i><span data-i18n="sectorArea">Área de Atividade</span></div>
      <div id="sectorFilters"></div>
    </div>

    <!-- MIN RATING -->
    <div class="filter-section">
      <div class="filter-section-title"><i data-lucide="star"></i><span data-i18n="minRating">Avaliação Mínima</span></div>
      <div class="filter-opt">
        <input type="radio" name="minRating" id="ratingAny" value="0" checked onchange="applyFilters()"/>
        <label for="ratingAny" data-i18n="ratingAny">Qualquer avaliação</label>
      </div>
      <div class="filter-opt">
        <input type="radio" name="minRating" id="rating48" value="4.8" onchange="applyFilters()"/>
        <label for="rating48"><span class="rating-stars-f">★★★★★</span> 4.8 <span data-i18n="ratingOrMore">ou mais</span></label>
      </div>
      <div class="filter-opt">
        <input type="radio" name="minRating" id="rating45" value="4.5" onchange="applyFilters()"/>
        <label for="rating45"><span class="rating-stars-f">★★★★★</span> 4.5 <span data-i18n="ratingOrMore">ou mais</span></label>
      </div>
      <div class="filter-opt">
        <input type="radio" name="minRating" id="rating40" value="4.0" onchange="applyFilters()"/>
        <label for="rating40"><span class="rating-stars-f">★★★★☆</span> 4.0 <span data-i18n="ratingOrMore">ou mais</span></label>
      </div>
    </div>

    <!-- RADIUS -->
    <div class="radius-section">
      <div class="radius-header">
        <span class="radius-label"><i data-lucide="target"></i><span data-i18n="searchRadius">Raio de Pesquisa</span></span>
        <span class="radius-value" id="rv">25 km</span>
      </div>
      <input type="range" class="radius-slider" min="1" max="100" value="25" id="radiusSlider"/>
      <div class="radius-marks">
        <span>1 km</span><span>25 km</span><span>50 km</span><span>100 km</span>
      </div>
    </div>

    <!-- STATUS -->
    <div class="filter-section">
      <div class="filter-section-title"><i data-lucide="award"></i><span data-i18n="featured">Destaque</span></div>
      <div class="filter-opt">
        <input type="checkbox" id="filterTopRated" onchange="applyFilters()"/>
        <label for="filterTopRated" data-i18n="topRated">Top Rated</label>
      </div>
      <div class="filter-opt">
        <input type="checkbox" id="filterVerified" onchange="applyFilters()"/>
        <label for="filterVerified" data-i18n="verified">Verificado</label>
      </div>
      <div class="filter-opt">
        <input type="checkbox" id="filterNew" onchange="applyFilters()"/>
        <label for="filterNew" data-i18n="newEntry">🆕 Novo Registo</label>
      </div>
    </div>

    <!-- TAGS -->
    <div class="tags-section">
      <div class="tags-section-title"><i data-lucide="tag"></i><span data-i18n="specialties">Especialidades</span></div>
      <div class="tags-cloud" id="tagsCloud"></div>
    </div>
  </div>

  <!-- MAP -->
  <div class="map-panel">
    <div id="map"></div>

    <div class="map-info-box">
      <div class="live-dot"></div>
      <span data-i18n="mapLive">Mapa em tempo real</span> · <span data-i18n="mapCity">Lisboa, Portugal</span>
    </div>
  </div>

</div>

</div><!-- /tab-search -->

<!-- DETAIL PANEL -->
<div class="detail-panel" id="detailPanel">
  <div class="dp-header">
    <div class="dp-logo" id="dpLogo"></div>
    <div class="dp-info">
      <div class="dp-name" id="dpName"></div>
      <div class="dp-sub" id="dpSub"></div>
    </div>
    <button class="dp-close" onclick="closeDetail()">✕</button>
  </div>
  <div class="dp-body">
    <div>
      <div class="dp-section-title"><i data-lucide="map-pin"></i><span data-i18n="detailLocation">Localização</span></div>
      <div class="dp-address" id="dpAddress"></div>
    </div>
    <div>
      <div class="dp-section-title"><i data-lucide="bar-chart-2"></i><span data-i18n="detailRating">Avaliação Multidimensional</span></div>
      <div class="rating-grid" id="dpRatings"></div>
    </div>
    <div>
      <div class="dp-section-title"><i data-lucide="phone-call"></i><span data-i18n="detailContact">Canais de Contacto</span></div>
      <div class="channel-grid">
        <div class="channel-btn wa" onclick="showToast(t('toastWhatsapp'))">
          <div class="ch-icon"><i data-lucide="message-circle"></i></div>
          <div class="ch-info">
            <div class="ch-name" data-i18n="waName">WhatsApp Direct</div>
            <div class="ch-desc" data-i18n="waDesc">Mensagem pré-preenchida com contexto</div>
          </div>
          <i data-lucide="arrow-up-right" class="ch-arrow"></i>
        </div>
        <div class="channel-btn chat" onclick="openChat()">
          <div class="ch-icon"><i data-lucide="message-square"></i></div>
          <div class="ch-info">
            <div class="ch-name" data-i18n="chatChannelName">Chat Interno</div>
            <div class="ch-desc" data-i18n="chatChannelDesc">Tempo real · PDF e ficheiros suportados</div>
          </div>
          <i data-lucide="arrow-up-right" class="ch-arrow"></i>
        </div>
        <div class="channel-btn email" onclick="openEmail()">
          <div class="ch-icon"><i data-lucide="mail"></i></div>
          <div class="ch-info">
            <div class="ch-name" data-i18n="emailChannelName">E-mail Gateway</div>
            <div class="ch-desc" data-i18n="emailChannelDesc">Pedido formal direto ao fornecedor</div>
          </div>
          <i data-lucide="arrow-up-right" class="ch-arrow"></i>
        </div>
      </div>
    </div>
    <div>
      <div class="dp-section-title"><i data-lucide="tag"></i><span data-i18n="detailSpecialties">Especialidades</span></div>
      <div class="card-tags" id="dpTags"></div>
    </div>
    <div id="dpReviewsSection">
      <div class="dp-section-title"><i data-lucide="message-circle"></i><span data-i18n="detailReviews">Avaliações Verificadas</span></div>
      <div id="dpReviews">
        <div class="review-item">
          <div class="review-top"><span class="review-name">TechCorp Lda.</span><span class="review-date">Jan 2025</span></div>
          <div class="stars">★★★★★</div>
          <div class="review-text" data-i18n="review1">"Excelente parceiro, entregou dentro do prazo e com qualidade acima do esperado."</div>
        </div>
        <div class="review-item">
          <div class="review-top"><span class="review-name">Ibérica Solutions SA</span><span class="review-date">Nov 2024</span></div>
          <div class="stars">★★★★☆</div>
          <div class="review-text" data-i18n="review2">"Boa comunicação e preços competitivos. Recomendado para projetos de médio prazo."</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- REGISTRATION MODAL -->
<div class="overlay" id="registerOverlay" onclick="closeRegisterIfBg(event)">
  <div class="modal">
    <div class="modal-title"><i data-lucide="building-2"></i><span data-i18n="regTitle">Registar Nova Empresa</span></div>
    <div class="modal-sub">
      <span data-i18n="regSub">Preencha os dados para adicionar a sua empresa à plataforma Linx. Campos com</span>
      <span class="req"> *</span>
      <span data-i18n="regSubSuffix">são obrigatórios.</span>
    </div>

    <div class="form-row">
      <label><span data-i18n="regCompanyName">Nome da Empresa</span> <span class="req">*</span></label>
      <input type="text" id="regName" data-i18n-ph="regNamePh"/>
    </div>

    <div class="form-grid2">
      <div class="form-row">
        <label><span data-i18n="regSectorLabel">Setor de Atividade</span> <span class="req">*</span></label>
        <select id="regSector"></select>
      </div>
      <div class="form-row">
        <label data-i18n="regCae">Código CAE</label>
        <input type="text" id="regCae" data-i18n-ph="regCaePh"/>
      </div>
    </div>

    <div class="form-row">
      <label><span data-i18n="regCountry">País</span> <span class="req">*</span></label>
      <select id="regCountry">
        <option value="">Selecione um país</option>
        <option value="pt">Portugal</option>
        <option value="es">Espanha</option>
        <option value="fr">França</option>
        <option value="it">Itália</option>
        <option value="de">Alemanha</option>
        <option value="uk">Reino Unido</option>
        <option value="nl">Países Baixos</option>
        <option value="be">Bélgica</option>
        <option value="ch">Suíça</option>
        <option value="at">Áustria</option>
        <option value="other">Outro país</option>
      </select>
    </div>

    <div class="form-grid2">
      <div class="form-row">
        <label><span data-i18n="regPostalCode">Código Postal</span> <span class="req">*</span></label>
        <input type="text" id="regPostalCode" placeholder="Ex: 1000-001"/>
      </div>
      <div class="form-row">
        <label><span data-i18n="regCity">Localidade / Cidade</span> <span class="req">*</span></label>
        <select id="regCity"></select>
      </div>
    </div>

    <div class="form-row">
      <label><span data-i18n="regAddress">Morada Detalhada</span> <span class="req">*</span></label>
      <input type="text" id="regAddress" data-i18n-ph="regAddressPh" placeholder="Ex: Rua da Paz, 123, Apto 4B"/>
      <div class="form-hint">Incluir rua, número, apartamento e complementos para localização precisa no mapa.</div>
    </div>

    <div class="form-row" style="display:none;">
      <label data-i18n="regZone">Zona / Área de Atuação</label>
      <select id="regZone"></select>
    </div>

    <div class="form-grid2">
      <div class="form-row">
        <label><span data-i18n="regEmail">Email de Contacto</span> <span class="req">*</span></label>
        <input type="email" id="regEmail" data-i18n-ph="regEmailPh"/>
      </div>
      <div class="form-row">
        <label data-i18n="regPhone">Telefone / WhatsApp</label>
        <input type="tel" id="regPhone" placeholder="+351 XXX XXX XXX"/>
      </div>
    </div>

    <div class="form-row">
      <label data-i18n="regWebsite">Website</label>
      <input type="url" id="regWebsite" data-i18n-ph="regWebsitePh"/>
    </div>

    <div class="form-row">
      <label><span data-i18n="regSpecialties">Especialidades</span> <span class="req">*</span></label>
      <input type="text" id="regTags" data-i18n-ph="regTagsPh"/>
      <div class="form-hint" data-i18n="regTagsHint">Separe as especialidades por vírgulas.</div>
    </div>

    <div class="form-row">
      <label data-i18n="regDescription">Descrição Breve</label>
      <textarea id="regDesc" data-i18n-ph="regDescPh"></textarea>
    </div>

    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeRegister()" data-i18n="regCancel">Cancelar</button>
      <button class="btn-submit" onclick="submitRegister()"><i data-lucide="check-circle"></i><span data-i18n="regSubmit">Registar Empresa</span></button>
    </div>
  </div>
</div>

<!-- EMAIL MODAL -->
<div class="overlay" id="emailOverlay" onclick="closeEmailIfBg(event)">
  <div class="modal modal-sm">
    <div class="modal-title"><i data-lucide="mail"></i><span data-i18n="emailTitle">Pedido de Orçamento</span></div>
    <div class="modal-sub" data-i18n="emailSub">Enviado diretamente para o fornecedor via e-mail verificado.</div>
    <div class="form-row">
      <label data-i18n="emailSubject">Assunto</label>
      <input type="text" id="emailSubjectInput" data-i18n-val="emailSubjectVal"/>
    </div>
    <div class="form-row">
      <label data-i18n="emailType">Tipo de Pedido</label>
      <select id="emailTypeSelect"></select>
    </div>
    <div class="form-row">
      <label data-i18n="emailMessage">Mensagem</label>
      <textarea id="emailMsgArea" data-i18n-val="emailMessageVal"></textarea>
    </div>
    <div class="form-row">
      <label data-i18n="emailAttach">Anexar ficheiro (opcional)</label>
      <input type="file" style="padding:6px"/>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeEmail()" data-i18n="emailCancel">Cancelar</button>
      <button class="btn-submit" onclick="submitEmail()"><i data-lucide="send"></i><span data-i18n="emailSend">Enviar Pedido</span></button>
    </div>
  </div>
</div>

<!-- ABOUT TAB -->
<section id="tab-about" class="tab-home" style="display:none;">
  <!-- HERO -->
  <div class="home-hero">
    <h1 class="hero-title">Sobre a LINX</h1>
    <p class="hero-sub">Conectando empresas e profissionais para criar oportunidades sem limites</p>
  </div>

  <div class="home-content">
    <!-- SOBRE A EMPRESA -->
    <div class="home-section">
      <div class="home-section-label">Quem Somos</div>
      <h2 class="home-section-title">LINX - Marketplace de Serviços Profissionais</h2>
      <p class="home-section-sub">A LINX é uma plataforma digital inovadora que conecta empresas, profissionais independentes e particulares, facilitando a criação de relações comerciais transparentes e confiáveis. Operamos em Portugal com o objetivo de democratizar o acesso a serviços de qualidade, eliminando intermediários e reduzindo custos.</p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px;">
        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 14px; padding: 28px; text-align: center;">
          <div style="font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 8px;">5K+</div>
          <p style="margin: 0; font-size: 14px; color: var(--muted);">Profissionais Verificados</p>
        </div>
        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 14px; padding: 28px; text-align: center;">
          <div style="font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 8px;">2K+</div>
          <p style="margin: 0; font-size: 14px; color: var(--muted);">Empresas Parceiras</p>
        </div>
      </div>
    </div>

    <!-- MISSÃO -->
    <div class="home-section">
      <div class="home-section-label">Nossa Jornada</div>
      <h2 class="home-section-title">Missão & Visão</h2>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 24px;">
        <div style="background: linear-gradient(135deg, rgba(249,115,22,.08) 0%, rgba(30,58,138,.08) 100%); border: 1.5px solid var(--border); border-radius: 14px; padding: 28px;">
          <h3 style="margin: 0 0 12px 0; font-size: 18px; font-weight: 800; color: var(--primary);">🎯 Missão</h3>
          <p style="margin: 0; font-size: 14px; color: var(--text); line-height: 1.7;">Simplificar e democratizar o acesso a serviços profissionais de qualidade, criando um ecossistema transparente onde empresas e profissionais podem crescer juntos, sem intermediários desnecessários.</p>
        </div>

        <div style="background: linear-gradient(135deg, rgba(249,115,22,.08) 0%, rgba(30,58,138,.08) 100%); border: 1.5px solid var(--border); border-radius: 14px; padding: 28px;">
          <h3 style="margin: 0 0 12px 0; font-size: 18px; font-weight: 800; color: var(--primary);">👁️ Visão</h3>
          <p style="margin: 0; font-size: 14px; color: var(--text); line-height: 1.7;">Ser a plataforma de referência em Portugal para conectar empresas e profissionais, promovendo crescimento económico e criando oportunidades para todos, independentemente do tamanho ou localização.</p>
        </div>
      </div>
    </div>

    <!-- VALORES -->
    <div class="home-section">
      <h2 class="home-section-title">Nossos Valores</h2>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px;">
        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 12px; padding: 20px; text-align: center;">
          <div style="font-size: 32px; margin-bottom: 12px;">✓</div>
          <h4 style="margin: 0 0 8px 0; font-size: 14px; font-weight: 800; color: var(--text);">Transparência</h4>
          <p style="margin: 0; font-size: 12px; color: var(--muted); line-height: 1.6;">Total honestidade nas relações comerciais</p>
        </div>

        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 12px; padding: 20px; text-align: center;">
          <div style="font-size: 32px; margin-bottom: 12px;">🤝</div>
          <h4 style="margin: 0 0 8px 0; font-size: 14px; font-weight: 800; color: var(--text);">Confiabilidade</h4>
          <p style="margin: 0; font-size: 12px; color: var(--muted); line-height: 1.6;">Profissionais e empresas verificados</p>
        </div>

        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 12px; padding: 20px; text-align: center;">
          <div style="font-size: 32px; margin-bottom: 12px;">⚡</div>
          <h4 style="margin: 0 0 8px 0; font-size: 14px; font-weight: 800; color: var(--text);">Eficiência</h4>
          <p style="margin: 0; font-size: 12px; color: var(--muted); line-height: 1.6;">Processos rápidos e sem barreiras</p>
        </div>
      </div>
    </div>

    <!-- APOIO AO CLIENTE -->
    <div class="home-section">
      <h2 class="home-section-title">Suporte ao Cliente</h2>
      <p class="home-section-sub">Estamos aqui para ajudar! Contacte-nos através dos seguintes canais:</p>

      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 28px;">
        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 14px; padding: 28px;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
            <div style="font-size: 24px;">💬</div>
            <h3 style="margin: 0; font-size: 15px; font-weight: 800; color: var(--text);">Chat em Tempo Real</h3>
          </div>
          <p style="margin: 0 0 14px 0; font-size: 13px; color: var(--muted);">Contacte-nos instantaneamente através do chat integrado na plataforma.</p>
          <button style="background: var(--primary); color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer;">Abrir Chat</button>
        </div>

        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 14px; padding: 28px;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
            <div style="font-size: 24px;">📧</div>
            <h3 style="margin: 0; font-size: 15px; font-weight: 800; color: var(--text);">Email</h3>
          </div>
          <p style="margin: 0 0 14px 0; font-size: 13px; color: var(--muted);">suporte@linx.pt</p>
          <p style="margin: 0 0 14px 0; font-size: 13px; color: var(--muted);">Resposta em até 24 horas úteis.</p>
          <button style="background: var(--primary); color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer;">Enviar Email</button>
        </div>

        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 14px; padding: 28px;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
            <div style="font-size: 24px;">📞</div>
            <h3 style="margin: 0; font-size: 15px; font-weight: 800; color: var(--text);">Telefone</h3>
          </div>
          <p style="margin: 0 0 14px 0; font-size: 13px; color: var(--muted);">+351 XXX XXX XXX</p>
          <p style="margin: 0 0 14px 0; font-size: 13px; color: var(--muted);">Seg-Sex: 09h-18h</p>
          <button style="background: var(--primary); color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer;">Ligar</button>
        </div>

        <div style="background: var(--surface); border: 1.5px solid var(--border); border-radius: 14px; padding: 28px;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
            <div style="font-size: 24px;">❓</div>
            <h3 style="margin: 0; font-size: 15px; font-weight: 800; color: var(--text);">FAQ</h3>
          </div>
          <p style="margin: 0 0 14px 0; font-size: 13px; color: var(--muted);">Encontre respostas às perguntas mais frequentes.</p>
          <button style="background: var(--primary); color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer;">Ver FAQ</button>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- CHAT WIDGET -->
<div class="chat-widget">
  <div class="chat-box" id="chatBox">
    <div class="chat-head">
      <div class="chat-head-avatar">🏭</div>
      <div class="chat-head-info">
        <div class="chat-head-name" id="chatName">–</div>
        <div class="chat-head-status" data-i18n="chatOnline">● Online agora</div>
      </div>
      <button class="chat-head-close" onclick="closeChat()">✕</button>
    </div>
    <div class="chat-msgs" id="chatMsgs">
      <div class="msg msg-in">
        <div class="msg-bubble" data-i18n="chatMsg1">Olá! Vi o vosso perfil na Linx. Podem enviar-me uma proposta?</div>
        <div class="msg-time">09:32</div>
      </div>
      <div class="msg msg-out">
        <div class="msg-bubble">
          <span data-i18n="chatMsg2">Bom dia! Com todo o gosto. Pode partilhar as especificações técnicas?</span>
          <div class="msg-file">📎 proposta_inicial.pdf · 1.2 MB</div>
        </div>
        <div class="msg-time">09:35 ✓✓</div>
      </div>
      <div class="msg msg-in">
        <div class="msg-bubble" data-i18n="chatMsg3">Perfeito, aqui ficam os detalhes do projeto.</div>
        <div class="msg-time">09:36</div>
      </div>
    </div>
    <div class="chat-input-bar">
      <div class="chat-attach" title="Anexar">📎</div>
      <input class="chat-input" id="chatInput" onkeydown="sendMsg(event)"/>
      <button class="chat-send" onclick="sendMsgBtn()">➤</button>
    </div>
  </div>
  <button class="chat-fab" onclick="toggleChat()"><i data-lucide="message-circle"></i>
    <div class="chat-notif" id="chatNotif">3</div>
  </button>
</div>

<div class="toast" id="toast"></div>

