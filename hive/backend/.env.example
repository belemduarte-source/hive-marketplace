# ── Database ──────────────────────────────────────────────────────────────────
# For thousands of concurrent users, point DATABASE_URL at a connection pooler
# (e.g. Neon's built-in pooler, Supabase PgBouncer, or Railway's proxy).
# Direct Postgres connections are limited (usually 100-200); a pooler multiplexes
# thousands of app connections onto a handful of real DB connections.
#
# Neon pooler URL looks like:  postgres://user:pass@ep-xxx.pooler.us-east-2.aws.neon.tech/db?sslmode=require
# Supabase pooler URL looks like: postgres://postgres.xxx:[pass]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/hive_db

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Email notifications ────────────────────────────────────────────────────────
# Gmail: use an App Password (not your normal password).
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=geral.savori@gmail.com
# Random secret — protects the approve/reject links in admin emails
ADMIN_TOKEN=change-this-to-a-long-random-secret
# Full public URL of the deployed app (no trailing slash)
APP_URL=https://your-project.vercel.app
